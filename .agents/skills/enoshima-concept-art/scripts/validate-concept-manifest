#!/usr/bin/env python3
"""Validate Enoshima concept coverage and implementation-bound visual evidence."""

from __future__ import annotations

import argparse
import hashlib
import itertools
import json
import re
import subprocess
import sys
from pathlib import Path
from typing import Any


VISIBLE_PATTERNS = (
    "home/dot_config/quickshell/cyberdock/*.qml",
    "home/dot_config/waybar/config.jsonc",
    "home/dot_config/waybar/style.css",
    "home/dot_config/swaync/config.json",
    "home/dot_config/swaync/style.css",
    "home/dot_config/hypr/hyprlock.conf",
    "ansible/roles/system/templates/enoshima-greeter.css.j2",
    "packages/local/enoshima-greeter/enoshima-greeter.c",
)
DIRECT_COLOR = re.compile(r"(?:#[0-9a-fA-F]{6,8}|\b(?:rgba?|hsla?)\s*\()")
HASH = re.compile(r"[0-9a-f]{64}")
REVIEW_WEIGHTS = {
    "geometry": 0.20,
    "color_tokens": 0.10,
    "text_overflow": 0.10,
    "perceptual": 0.10,
    "hierarchy": 0.15,
    "interaction": 0.15,
    "state_meaning": 0.10,
    "accessibility_localization": 0.10,
}
AUTOMATED_CATEGORIES = {"geometry", "color_tokens", "text_overflow", "perceptual"}


def load_yaml(path: Path) -> object:
    completed = subprocess.run(["yq", ".", str(path)], check=True, capture_output=True, text=True)
    return json.loads(completed.stdout)


def sha256(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as stream:
        for chunk in iter(lambda: stream.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def implementation_digest(root: Path, implementations: list[str]) -> str:
    digest = hashlib.sha256()
    for value in sorted(implementations):
        path = root / value
        digest.update(value.encode("utf-8"))
        digest.update(b"\0")
        digest.update(path.read_bytes())
        digest.update(b"\0")
    return digest.hexdigest()


def fail(errors: list[str], message: str) -> None:
    errors.append(message)


def relative_path(root: Path, value: object, errors: list[str], label: str) -> Path | None:
    if not isinstance(value, str) or not value:
        fail(errors, f"{label}: expected a non-empty repository-relative path")
        return None
    path = Path(value)
    if path.is_absolute() or ".." in path.parts:
        fail(errors, f"{label}: path must stay inside the repository: {value}")
        return None
    candidate = root / path
    resolved = candidate.resolve()
    try:
        resolved.relative_to(root)
    except ValueError:
        fail(errors, f"{label}: resolved path escapes the repository: {value}")
        return None
    if candidate.is_symlink():
        fail(errors, f"{label}: symbolic links are not accepted: {value}")
        return None
    return resolved


def validate_review(
    root: Path,
    surface_id: str,
    evidence: dict[str, Any],
    current_digest: str,
    concept_hash: str,
    concept_spec_hash: str,
    errors: list[str],
) -> None:
    label = f"surfaces.{surface_id}.evidence"
    review_path = relative_path(root, evidence.get("review"), errors, f"{label}.review")
    if review_path is None or not review_path.is_file():
        fail(errors, f"{label}.review: approved evidence requires a review JSON file")
        return
    try:
        review = json.loads(review_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        fail(errors, f"{label}.review: cannot read JSON: {error}")
        return
    if review.get("schema") != 2 or review.get("surface_id") != surface_id:
        fail(errors, f"{label}.review: schema/surface_id mismatch")
    if (
        review.get("implementation_digest") != current_digest
        or review.get("concept_sha256") != concept_hash
        or review.get("concept_spec_sha256") != concept_spec_hash
    ):
        fail(errors, f"{label}.review: stale implementation or concept digest")
    scores = review.get("scores", {})
    if not isinstance(scores, dict):
        fail(errors, f"{label}.review.scores: expected a mapping")
        return
    automated_path = relative_path(root, review.get("automated_report"), errors, f"{label}.review.automated_report")
    automated_scores: dict[str, Any] = {}
    if automated_path is None or not automated_path.is_file():
        fail(errors, f"{label}.review.automated_report: report does not exist")
    else:
        try:
            automated = json.loads(automated_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as error:
            fail(errors, f"{label}.review.automated_report: cannot read JSON: {error}")
            automated = {}
        if review.get("automated_report_sha256") != sha256(automated_path):
            fail(errors, f"{label}.review.automated_report: report hash mismatch")
        if (
            automated.get("schema") != 1
            or automated.get("surface_id") != surface_id
            or automated.get("implementation_digest") != current_digest
            or automated.get("concept_sha256") != concept_hash
            or automated.get("concept_spec_sha256") != concept_spec_hash
        ):
            fail(errors, f"{label}.review.automated_report: stale schema or digest")
        if automated.get("text_overflow_failures"):
            fail(errors, f"{label}.review.automated_report: text overflow failures remain")
        value = automated.get("scores", {})
        if isinstance(value, dict):
            automated_scores = value

    weighted = 0.0
    for category, weight in REVIEW_WEIGHTS.items():
        score = scores.get(category)
        if not isinstance(score, (int, float)) or not 0 <= score <= 100:
            fail(errors, f"{label}.review.scores.{category}: expected 0..100")
            continue
        if score < 85:
            fail(errors, f"{label}.review.scores.{category}: {score} is below the 85 category floor")
        if category in AUTOMATED_CATEGORIES and automated_scores.get(category) != score:
            fail(errors, f"{label}.review.scores.{category}: must equal the automated report")
        weighted += float(score) * weight
    if round(weighted, 2) < 90:
        fail(errors, f"{label}.review: weighted score {weighted:.2f} is below 90")
    if abs(float(review.get("total", -1)) - round(weighted, 2)) > 0.01:
        fail(errors, f"{label}.review.total: must equal weighted score {weighted:.2f}")


def validate_evidence(
    root: Path,
    surface_id: str,
    entry: dict[str, Any],
    spec_states: list[str],
    concept_hash: str,
    concept_spec_hash: str,
    require_evidence: bool,
    errors: list[str],
    pending: list[str],
) -> None:
    label = f"surfaces.{surface_id}.evidence"
    evidence = entry.get("evidence")
    if not isinstance(evidence, dict):
        fail(errors, f"{label}: schema 2 requires an evidence mapping")
        return
    status = evidence.get("status")
    if status not in ("pending", "approved"):
        fail(errors, f"{label}.status: expected pending or approved")
        return
    required_states = evidence.get("required_states")
    required_locales = evidence.get("required_locales")
    required_scales = evidence.get("required_scales")
    if not isinstance(required_states, list) or set(required_states) != set(spec_states):
        fail(errors, f"{label}.required_states: must exactly match the concept spec states")
    if not isinstance(required_locales, list) or not {"en_US.UTF-8", "ko_KR.UTF-8"}.issubset(set(required_locales)):
        fail(errors, f"{label}.required_locales: English and Korean are required")
    if not isinstance(required_scales, list) or not {1.0, 1.25, 2.0}.issubset({float(value) for value in required_scales}):
        fail(errors, f"{label}.required_scales: 1.0, 1.25, and 2.0 are required")

    implementations = entry.get("implementation", [])
    try:
        current_digest = implementation_digest(root, implementations)
    except OSError as error:
        fail(errors, f"{label}: cannot hash implementation: {error}")
        return

    if status == "pending":
        pending.append(surface_id)
        if evidence.get("captures") or evidence.get("review") or evidence.get("implementation_digest"):
            fail(errors, f"{label}: pending evidence must not carry partial approval artifacts")
        if require_evidence:
            fail(errors, f"{label}.status: visual release requires approved evidence")
        return

    if evidence.get("implementation_digest") != current_digest:
        fail(errors, f"{label}.implementation_digest: stale or incorrect; expected {current_digest}")
    captures = evidence.get("captures")
    if not isinstance(captures, list) or not captures:
        fail(errors, f"{label}.captures: approved evidence requires capture sidecars")
        return

    matrix: set[tuple[str, str, float]] = set()
    for value in captures:
        sidecar_path = relative_path(root, value, errors, f"{label}.captures")
        if sidecar_path is None or not sidecar_path.is_file():
            fail(errors, f"{label}.captures: sidecar does not exist: {value}")
            continue
        try:
            sidecar = json.loads(sidecar_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as error:
            fail(errors, f"{label}.captures: invalid sidecar {value}: {error}")
            continue
        if sidecar.get("schema") != 1 or sidecar.get("surface_id") != surface_id:
            fail(errors, f"{label}.captures: schema/surface mismatch in {value}")
        if (
            sidecar.get("implementation_digest") != current_digest
            or sidecar.get("concept_sha256") != concept_hash
            or sidecar.get("concept_spec_sha256") != concept_spec_hash
        ):
            fail(errors, f"{label}.captures: stale digest in {value}")
        image_path = relative_path(root, sidecar.get("image"), errors, f"{label}.captures.image")
        if image_path is None or not image_path.is_file():
            fail(errors, f"{label}.captures: screenshot does not exist for {value}")
        elif sidecar.get("image_sha256") != sha256(image_path):
            fail(errors, f"{label}.captures: screenshot hash mismatch in {value}")
        logical_size = sidecar.get("logical_size")
        if not isinstance(logical_size, list) or len(logical_size) != 2 or not all(isinstance(item, int) and item > 0 for item in logical_size):
            fail(errors, f"{label}.captures: invalid logical_size in {value}")
        try:
            matrix.add((str(sidecar["state"]), str(sidecar["locale"]), float(sidecar["scale"])))
        except (KeyError, TypeError, ValueError):
            fail(errors, f"{label}.captures: state/locale/scale missing in {value}")

    expected = set(itertools.product(required_states, required_locales, (float(value) for value in required_scales)))
    missing = expected - matrix
    if missing:
        preview = ", ".join(f"{state}/{locale}/{scale:g}" for state, locale, scale in sorted(missing)[:5])
        fail(errors, f"{label}.captures: missing {len(missing)} matrix entries (for example {preview})")
    validate_review(
        root,
        surface_id,
        evidence,
        current_digest,
        concept_hash,
        concept_spec_hash,
        errors,
    )


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("manifest", nargs="?", default="docs/ui-surfaces.yaml")
    parser.add_argument("--require-evidence", action="store_true")
    args = parser.parse_args()

    manifest = Path(args.manifest).resolve()
    root = manifest.parent.parent
    errors: list[str] = []
    pending: list[str] = []
    try:
        data = load_yaml(manifest)
    except (OSError, subprocess.CalledProcessError, json.JSONDecodeError) as exc:
        print(f"concept manifest: cannot read {manifest}: {exc}", file=sys.stderr)
        return 1

    if not isinstance(data, dict) or data.get("schema") != 2:
        print("concept manifest: schema must be 2", file=sys.stderr)
        return 1
    surfaces = data.get("surfaces")
    exemptions = data.get("exemptions", {})
    if not isinstance(surfaces, dict) or not surfaces:
        print("concept manifest: surfaces must be a non-empty mapping", file=sys.stderr)
        return 1
    if not isinstance(exemptions, dict):
        print("concept manifest: exemptions must be a mapping", file=sys.stderr)
        return 1

    registered: set[str] = set()
    for surface_id, entry in surfaces.items():
        label = f"surfaces.{surface_id}"
        if not re.fullmatch(r"[a-z0-9]+(?:-[a-z0-9]+)*", str(surface_id)):
            fail(errors, f"{label}: invalid surface id")
        if not isinstance(entry, dict):
            fail(errors, f"{label}: expected a mapping")
            continue
        implementations = entry.get("implementation", [])
        if not isinstance(implementations, list) or not implementations:
            fail(errors, f"{label}.implementation: expected a non-empty list")
            continue
        planned = bool(entry.get("planned", False))
        for value in implementations:
            path = relative_path(root, value, errors, f"{label}.implementation")
            if path is None:
                continue
            registered.add(path.relative_to(root).as_posix())
            if not planned and not path.is_file():
                fail(errors, f"{label}: implementation does not exist: {value}")

        concept = entry.get("concept")
        if not isinstance(concept, dict) or concept.get("status") != "approved":
            fail(errors, f"{label}.concept.status: must be approved")
            continue
        asset_path = relative_path(root, concept.get("asset"), errors, f"{label}.concept.asset")
        spec_path = relative_path(root, concept.get("spec"), errors, f"{label}.concept.spec")
        concept_hash = str(concept.get("sha256", ""))
        if not HASH.fullmatch(concept_hash):
            fail(errors, f"{label}.concept.sha256: expected a SHA-256 digest")
        elif asset_path is not None and asset_path.is_file() and sha256(asset_path) != concept_hash:
            fail(errors, f"{label}.concept.sha256: concept asset has changed")
        if asset_path is not None and not asset_path.is_file():
            fail(errors, f"{label}.concept.asset: file does not exist")

        spec_states: list[str] = []
        concept_spec_hash = ""
        if spec_path is None or not spec_path.is_file():
            fail(errors, f"{label}.concept.spec: file does not exist")
        else:
            concept_spec_hash = sha256(spec_path)
            try:
                spec = load_yaml(spec_path)
            except (OSError, subprocess.CalledProcessError, json.JSONDecodeError) as exc:
                fail(errors, f"{label}.concept.spec: cannot read: {exc}")
                spec = None
            if not isinstance(spec, dict) or spec.get("surface_id") != surface_id:
                fail(errors, f"{label}.concept.spec: surface_id must equal {surface_id}")
            elif not isinstance(spec.get("states"), list) or not spec.get("states") or not spec.get("acceptance"):
                fail(errors, f"{label}.concept.spec: states and acceptance are required")
            else:
                spec_states = [str(value) for value in spec["states"]]

        validate_evidence(
            root,
            str(surface_id),
            entry,
            spec_states,
            concept_hash,
            concept_spec_hash,
            args.require_evidence,
            errors,
            pending,
        )

        if entry.get("token_mode") == "consumer":
            for value in implementations:
                path = root / value
                if path.suffix == ".qml" and path.is_file():
                    for number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
                        if DIRECT_COLOR.search(line) and 'color: "transparent"' not in line:
                            fail(errors, f"{value}:{number}: token consumer contains a direct color literal")

    for pattern in VISIBLE_PATTERNS:
        for path in root.glob(pattern):
            relative = path.relative_to(root).as_posix()
            if relative in registered:
                continue
            reason = exemptions.get(relative)
            if not isinstance(reason, str) or not reason.strip():
                fail(errors, f"unregistered visible implementation: {relative}")

    for value, reason in exemptions.items():
        path = relative_path(root, value, errors, "exemptions")
        if path is not None and not path.is_file():
            fail(errors, f"exemption target does not exist: {value}")
        if not isinstance(reason, str) or len(reason.strip()) < 12:
            fail(errors, f"exemptions.{value}: provide a specific reason")

    if errors:
        for error in errors:
            print(f"concept manifest: {error}", file=sys.stderr)
        return 1
    suffix = f"; {len(pending)} visual evidence sets pending" if pending else "; all visual evidence approved and current"
    print(f"concept manifest: {len(surfaces)} surfaces approved and registered{suffix}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
