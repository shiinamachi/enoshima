#!/usr/bin/env bash
set -euo pipefail

readonly preset_dir=${ENOSHIMA_UKI_PRESET_DIR:-/etc/mkinitcpio.d}
readonly mkinitcpio_bin=${ENOSHIMA_UKI_MKINITCPIO:-/usr/bin/mkinitcpio}
readonly objcopy_bin=${ENOSHIMA_UKI_OBJCOPY:-/usr/bin/objcopy}
readonly cmdline_file=${ENOSHIMA_UKI_CMDLINE_FILE:-/etc/kernel/cmdline}
readonly output_root=${ENOSHIMA_UKI_OUTPUT_ROOT:-/efi/EFI/Linux}
readonly temp_root=${ENOSHIMA_UKI_TEMP_DIR:-/run}
readonly secure_boot_signing=${ENOSHIMA_UKI_SECURE_BOOT_SIGNING:-false}
readonly sbsign_bin=${ENOSHIMA_UKI_SBSIGN:-/usr/bin/sbsign}
readonly sbverify_bin=${ENOSHIMA_UKI_SBVERIFY:-/usr/bin/sbverify}
readonly secure_boot_key=${ENOSHIMA_UKI_SECURE_BOOT_KEY:-/var/lib/sbctl/keys/db/db.key}
readonly secure_boot_certificate=${ENOSHIMA_UKI_SECURE_BOOT_CERTIFICATE:-/var/lib/sbctl/keys/db/db.pem}

die() {
  printf 'enoshima-rebuild-uki: %s\n' "$*" >&2
  exit 1
}

normalize_cmdline() {
  tr '\n\t' '  ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
}

[[ $EUID -eq 0 || ${ENOSHIMA_UKI_ALLOW_UNPRIVILEGED:-false} == true ]] ||
  die 'root privileges are required'
[[ -d $preset_dir && ! -L $preset_dir ]] || die "invalid preset directory: $preset_dir"
[[ -r $cmdline_file && ! -L $cmdline_file ]] || die "invalid kernel command line: $cmdline_file"
command -v "$mkinitcpio_bin" >/dev/null 2>&1 || die "mkinitcpio is unavailable: $mkinitcpio_bin"
command -v "$objcopy_bin" >/dev/null 2>&1 || die "objcopy is unavailable: $objcopy_bin"
case $secure_boot_signing in
  true)
    command -v "$sbsign_bin" >/dev/null 2>&1 || die "sbsign is unavailable: $sbsign_bin"
    command -v "$sbverify_bin" >/dev/null 2>&1 || die "sbverify is unavailable: $sbverify_bin"
    [[ -r $secure_boot_key && ! -L $secure_boot_key ]] ||
      die "Secure Boot signing key is unavailable"
    [[ -r $secure_boot_certificate && ! -L $secure_boot_certificate ]] ||
      die "Secure Boot signing certificate is unavailable"
    ;;
  false) ;;
  *) die 'ENOSHIMA_UKI_SECURE_BOOT_SIGNING must be true or false' ;;
esac

canonical_root=$(realpath -m -- "$output_root")
expected_cmdline=$(normalize_cmdline <"$cmdline_file")
[[ -n $expected_cmdline ]] || die 'kernel command line is empty'

shopt -s nullglob
presets=("$preset_dir"/*.preset)
((${#presets[@]} > 0)) || die "no UKI presets found in $preset_dir"

for preset in "${presets[@]}"; do
  grep -Eq '^PRESETS=.*default' "$preset" || continue
  destination=$(sed -n -E 's/^default_uki="([^"]+)"$/\1/p' "$preset" | head -n 1)
  [[ $destination == /* ]] || die "$preset has no absolute default_uki"
  canonical_destination=$(realpath -m -- "$destination")
  case $canonical_destination in
    "$canonical_root"/*) ;;
    *) die "$destination escapes the managed UKI output root" ;;
  esac
  [[ -d ${destination%/*} && ! -L ${destination%/*} ]] ||
    die "UKI output directory is unavailable: ${destination%/*}"

  name=${destination##*/}
  stem=${name%.efi}
  candidate=${destination%/*}/.${name}.enoshima-new
  previous=${destination%/*}/${stem}-previous.efi
  previous_candidate=${destination%/*}/.${stem}-previous.enoshima-new
  signed_candidate=${destination%/*}/.${name}.enoshima-signed
  temporary_preset=$(mktemp "$temp_root/enoshima-uki-preset.XXXXXX")
  cmdline_dump=$(mktemp "$temp_root/enoshima-uki-cmdline.XXXXXX")
  objcopy_output=$(mktemp "$temp_root/enoshima-uki-inspection.XXXXXX")

  cleanup_iteration() {
    rm -f -- \
      "$temporary_preset" \
      "$cmdline_dump" \
      "$objcopy_output" \
      "$candidate" \
      "$previous_candidate" \
      "$signed_candidate"
  }
  trap cleanup_iteration EXIT INT TERM

  sed -E "s#^default_uki=\"[^\"]+\"#default_uki=\"$candidate\"#" \
    "$preset" >"$temporary_preset"
  chmod 0600 "$temporary_preset"

  "$mkinitcpio_bin" -p "$temporary_preset"
  [[ -s $candidate && ! -L $candidate ]] || die "candidate UKI was not created: $candidate"
  # With no explicit output, objcopy rewrites the input PE in place and drops
  # its Authenticode overlay. Write the inspected PE to a disposable regular
  # file so the candidate stays intact; /dev/null is not a valid PE output.
  "$objcopy_bin" \
    --dump-section ".cmdline=$cmdline_dump" \
    "$candidate" \
    "$objcopy_output" 2>/dev/null ||
    die "candidate UKI has no readable .cmdline section: $candidate"
  embedded_cmdline=$(tr -d '\0' <"$cmdline_dump" | normalize_cmdline)
  [[ $embedded_cmdline == "$expected_cmdline" ]] ||
    die "candidate UKI command line does not match $cmdline_file"
  if [[ $secure_boot_signing == true ]]; then
    "$sbsign_bin" \
      --key "$secure_boot_key" \
      --cert "$secure_boot_certificate" \
      --output "$signed_candidate" \
      "$candidate"
    [[ -s $signed_candidate && ! -L $signed_candidate ]] ||
      die "signed UKI candidate was not created: $signed_candidate"
    "$sbverify_bin" --cert "$secure_boot_certificate" "$signed_candidate" ||
      die "signed UKI candidate verification failed: $signed_candidate"
    mv -f -- "$signed_candidate" "$candidate"
  fi

  if [[ -e $destination ]]; then
    [[ -f $destination && ! -L $destination ]] || die "unsafe current UKI: $destination"
    current_hash=$(sha256sum "$destination" | awk '{print $1}')
    cp -- "$destination" "$previous_candidate"
    chmod 0644 "$previous_candidate"
    sync -f "$previous_candidate" 2>/dev/null || true
    mv -f -- "$previous_candidate" "$previous"
    sync -f "${destination%/*}" 2>/dev/null || true
    [[ $(sha256sum "$previous" | awk '{print $1}') == "$current_hash" ]] ||
      die "rollback UKI verification failed: $previous"
  fi
  chmod 0644 "$candidate"
  candidate_hash=$(sha256sum "$candidate" | awk '{print $1}')
  sync -f "$candidate" 2>/dev/null || true
  mv -f -- "$candidate" "$destination"
  sync -f "$destination" 2>/dev/null || true
  sync -f "${destination%/*}" 2>/dev/null || true
  [[ $(sha256sum "$destination" | awk '{print $1}') == "$candidate_hash" ]] ||
    die "installed UKI verification failed: $destination"
  [[ ! -e $previous || -s $previous ]] || die "rollback UKI is empty: $previous"
  printf 'Installed verified UKI %s; rollback is %s\n' "$destination" "$previous"

  trap - EXIT INT TERM
  cleanup_iteration
done
