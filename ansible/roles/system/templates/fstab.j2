# Static information about the filesystems.
# See fstab(5) for details.

# Root is selected by the UKI command line and the ESP is discovered by
# systemd-gpt-auto-generator on this host. The dedicated swap subvolume is
# managed only when disk-backed hibernation is enabled.
# <file system> <dir> <type> <options> <dump> <pass>
{% if desktop_hibernation_enabled | bool %}
UUID={{ root_btrfs_uuid }} /swap btrfs subvol=@swap,noatime,compress=no 0 0
/swap/swapfile none swap defaults,pri=10 0 0
{% endif %}
