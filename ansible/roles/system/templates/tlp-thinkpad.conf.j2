# ThinkPad profiles extend TLP's complete laptop defaults. Hardware known to
# affect WWAN, biometric, camera, or dock resume is excluded explicitly below.
TLP_AUTO_SWITCH=1
TLP_PROFILE_AC=PRF
TLP_PROFILE_BAT=BAL

PLATFORM_PROFILE_ON_AC=performance
PLATFORM_PROFILE_ON_BAT=balanced
PLATFORM_PROFILE_ON_SAV=low-power

CPU_ENERGY_PERF_POLICY_ON_AC=performance
CPU_ENERGY_PERF_POLICY_ON_BAT=balance_power
CPU_ENERGY_PERF_POLICY_ON_SAV=power

CPU_BOOST_ON_AC=1
CPU_BOOST_ON_BAT=1
CPU_BOOST_ON_SAV=0

PCIE_ASPM_ON_AC=default
PCIE_ASPM_ON_BAT=powersave
PCIE_ASPM_ON_SAV=powersupersave

WIFI_PWR_ON_AC=off
WIFI_PWR_ON_BAT=on

RUNTIME_PM_ON_AC=on
RUNTIME_PM_ON_BAT=auto
RUNTIME_PM_DENYLIST="{{ tlp_runtime_pm_denylist }}"

USB_AUTOSUSPEND=1
USB_DENYLIST="{{ tlp_usb_denylist }}"
USB_EXCLUDE_WWAN=1
