#%PAM-1.0

# Enter a password normally, or submit an empty password to start fprintd.
auth        required    pam_faillock.so preauth
-auth       [success=3 default=ignore] pam_systemd_home.so
auth        [success=2 new_authtok_reqd=2 default=ignore] pam_unix.so try_first_pass likeauth nullok
auth        [success=1 default=bad] pam_fprintd.so timeout=15 max-tries=3
auth        [default=die] pam_faillock.so authfail
auth        optional    pam_permit.so
auth        required    pam_env.so
auth        required    pam_faillock.so authsucc
account     include     system-auth
session     include     system-auth
session     optional    pam_systemd.so class=none
