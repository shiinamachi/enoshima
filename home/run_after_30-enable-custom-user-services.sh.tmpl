#!/usr/bin/env bash
set -euo pipefail

units=(
  cyberdock.service
  hyprlauncher.service
  xembed-sni-proxy.service
)

# Hyprbars used to add the same compositor titlebar to every client. Retire
# that optional plugin and its user files so applications can own decorations.
systemctl --user disable --now hyprbars-check.service 2>/dev/null || true
rm -f -- \
  "$HOME/.config/systemd/user/hyprbars-check.service" \
  "$HOME/.local/bin/hyprbars-green" \
  "$HOME/.local/bin/hyprbars-setup"

hyprbars_state=${XDG_STATE_HOME:-$HOME/.local/state}/hyprbars
if command -v hyprpm >/dev/null 2>&1 &&
  /usr/bin/sudo -n -v >/dev/null 2>&1; then
  hyprpm disable hyprbars >/dev/null 2>&1 || true
  if [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]]; then
    hyprpm reload >/dev/null 2>&1 &&
      hyprctl reload config-only >/dev/null 2>&1 || true
  fi
fi
rm -f -- "$hyprbars_state/hyprland-abi" "$hyprbars_state/setup.lock"
rmdir -- "$hyprbars_state" 2>/dev/null || true

configuration_consumers=(
  hypridle.service
  hyprpaper.service
  swaync.service
  waybar.service
)

systemctl --user daemon-reload
systemctl --user enable "${units[@]}"

if systemctl --user --quiet is-active graphical-session.target; then
  # Chezmoi runs after Ansible has started the existing user units. Refresh
  # every long-running consumer whose configuration was just deployed.
  systemctl --user restart "${units[@]}" "${configuration_consumers[@]}"
fi
