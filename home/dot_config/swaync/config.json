{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "layer-shell-cover-screen": true,
  "cssPriority": "user",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 14,
  "control-center-margin-right": 14,
  "control-center-margin-left": 14,
  "notification-2fa-action": true,
  "notification-inline-replies": true,
  "notification-body-image-height": 120,
  "notification-body-image-width": 240,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "relative-timestamps": true,
  "control-center-width": 460,
  "control-center-height": 850,
  "notification-window-width": 440,
  "keyboard-shortcuts": true,
  "notification-grouping": true,
  "image-visibility": "when-available",
  "transition-time": 0,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "No notifications",
  "script-fail-notify": true,
  "widgets": [
    "title",
    "dnd",
    "buttons-grid#quick-settings",
    "volume",
    "backlight",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "notifications": {
      "vexpand": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "buttons-grid#quick-settings": {
      "buttons-per-row": 3,
      "actions": [
        {
          "label": "Wi-Fi",
          "type": "toggle",
          "command": "swaync-quick-setting apply wifi",
          "update-command": "swaync-quick-setting status wifi"
        },
        {
          "label": "Bluetooth",
          "type": "toggle",
          "command": "swaync-quick-setting apply bluetooth",
          "update-command": "swaync-quick-setting status bluetooth"
        },
        {
          "label": "Night Light",
          "type": "toggle",
          "command": "swaync-quick-setting apply night-light",
          "update-command": "swaync-quick-setting status night-light"
        },
        {
          "label": "Power",
          "type": "normal",
          "command": "hyprshutdown"
        },
        {
          "label": "Audio",
          "type": "normal",
          "command": "hyprpwcenter"
        },
        {
          "label": "Display",
          "type": "normal",
          "command": "desktop-display-mode menu"
        }
      ]
    },
    "volume": {
      "label": "󰕾  Volume",
      "show-per-app": false
    },
    "backlight": {
      "label": "󰃠  Brightness",
      "device": "intel_backlight",
      "subsystem": "backlight",
      "min": 1
    },
    "mpris": {
      "autohide": true,
      "show-album-art": "when-available",
      "loop-carousel": false
    }
  }
}
