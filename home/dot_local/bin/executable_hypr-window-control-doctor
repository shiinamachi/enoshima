#!/usr/bin/env bash
# shellcheck disable=SC2016 # jq variables are intentionally single-quoted.
set -euo pipefail

readonly hyprctl_bin=${HYPR_WINDOW_DOCTOR_HYPRCTL:-hyprctl}
readonly jq_bin=${HYPR_WINDOW_DOCTOR_JQ:-jq}

die() {
  printf 'hypr-window-control-doctor: %s\n' "$*" >&2
  exit 1
}

[[ $# -eq 0 || ($# -eq 1 && $1 == --json) ]] ||
  die 'usage: hypr-window-control-doctor [--json]'
command -v "$hyprctl_bin" >/dev/null 2>&1 || die "hyprctl command not found: $hyprctl_bin"
command -v "$jq_bin" >/dev/null 2>&1 || die "jq command not found: $jq_bin"

binds=$("$hyprctl_bin" binds -j) || die 'cannot query effective binds'
devices=$("$hyprctl_bin" devices -j) || die 'cannot query input devices'
active=$("$hyprctl_bin" activewindow -j) || die 'cannot query active window'
submap=$("$hyprctl_bin" submap -j 2>/dev/null || printf '"unknown"')
resize_border=$("$hyprctl_bin" getoption general:resize_on_border -j 2>/dev/null || printf '{}')
grab_area=$("$hyprctl_bin" getoption general:extend_border_grab_area -j 2>/dev/null || printf '{}')
version=$("$hyprctl_bin" version 2>/dev/null | head -n1 || true)
plugins=$("$hyprctl_bin" plugin list -j 2>/dev/null || printf '[]')

report=$("$jq_bin" -c -n \
  --arg version "$version" \
  --argjson binds "$binds" \
  --argjson devices "$devices" \
  --argjson active "$active" \
  --argjson plugins "$plugins" \
  --argjson submap "$submap" \
  --argjson resizeBorder "$resize_border" \
  --argjson grabArea "$grab_area" '
  def effective_mouse_bind($key; $description):
    any($binds[];
      .key == $key and ((.modmask // 0) % 128 >= 64) and
      (
        (.mouse // false) == true or
        (
          .dispatcher == "__lua" and
          (.has_description // false) == true and
          .description == $description
        )
      )
    );
  def effective_key_bind($key; $description):
    any($binds[];
      .key == $key and ((.modmask // 0) % 128 >= 64)
      and (.has_description // false) == true
      and .description == $description
    );

  {
    schema: 1,
    version: $version,
    effective: {
      move: effective_mouse_bind("mouse:272"; "Move window with pointer"),
      resize: effective_mouse_bind("mouse:273"; "Resize window with pointer"),
      snap_left: effective_key_bind("left"; "Place the active window like Windows Snap"),
      snap_right: effective_key_bind("right"; "Place the active window like Windows Snap"),
      snap_maximize: effective_key_bind("up"; "Place the active window like Windows Snap"),
      snap_minimize: effective_key_bind("down"; "Place the active window like Windows Snap"),
      system_titlebar: any($plugins[]; .name == "enoshima-decoration"),
      resize_on_border: ($resizeBorder.bool // false),
      border_grab_area: ($grabArea.int // 0)
    },
    submap: $submap,
    active_window: {
      address: ($active.address // ""),
      class: ($active.class // ""),
      title_redacted: true
    },
    mice: [
      $devices.mice[]? | {
        name: (.name // "unknown"),
        address: (.address // "")
      }
    ],
    healthy: (
      effective_mouse_bind("mouse:272"; "Move window with pointer")
      and effective_mouse_bind("mouse:273"; "Resize window with pointer")
      and effective_key_bind("left"; "Place the active window like Windows Snap")
      and effective_key_bind("right"; "Place the active window like Windows Snap")
      and effective_key_bind("up"; "Place the active window like Windows Snap")
      and effective_key_bind("down"; "Place the active window like Windows Snap")
      and any($plugins[]; .name == "enoshima-decoration")
      and ($resizeBorder.bool // false)
      and ($grabArea.int // 0) >= 24
    )
  }')

if [[ ${1:-} == --json ]]; then
  printf '%s\n' "$report"
else
  "$jq_bin" -r '
    "Hyprland: \(.version)",
    "Submap: \(.submap)",
    "Move bind (Super+left): \(.effective.move)",
    "Resize bind (Super+right): \(.effective.resize)",
    "Windows-style Snap keys: \([.effective.snap_left, .effective.snap_right, .effective.snap_maximize, .effective.snap_minimize] | all)",
    "Enoshima system titlebar: \(.effective.system_titlebar)",
    "Border resize: \(.effective.resize_on_border) (grab area \(.effective.border_grab_area))",
    "Pointer devices:",
    (.mice[] | "- \(.name) [\(.address)]"),
    "Healthy: \(.healthy)"
  ' <<<"$report"
fi

"$jq_bin" -e '.healthy' <<<"$report" >/dev/null
