#!/usr/bin/env bash

# Explicit, interactive one-time setup for KakaoTalk. The Wine prefix, login,
# downloaded installer, and Bottles state remain outside this repository.
set -euo pipefail

readonly app_id=com.usebottles.bottles
readonly bottle_name=KakaoTalk
readonly program_name=KakaoTalk
readonly installer_url=https://app-pc.kakaocdn.net/talk/win32/x64/KakaoTalk_Setup.exe
readonly flathub_url=https://dl.flathub.org/repo/flathub.flatpakrepo

die() {
  printf 'kakaotalk-setup: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "required command is missing: $1"
}

require_command flatpak
require_command curl
require_command jq
require_command kakaotalk-connectivity-check
require_command kakaotalk-profile
require_command timeout
require_command xdg-user-dir

[[ -t 0 ]] || die 'run this helper interactively from a terminal'
[[ -n ${WAYLAND_DISPLAY:-}${DISPLAY:-} ]] ||
  die 'run this helper inside the graphical Hyprland session'

cat <<'EOF'
This will create a user-scoped Bottles installation and a dedicated
64-bit "KakaoTalk" application bottle. It grants Bottles read/write access
only to Downloads, Documents, and Pictures, downloads KakaoTalk from Kakao's
official CDN, and opens the Windows installer.

No Kakao account credentials or Wine prefix data are written to this Git
repository.
EOF

read -r -p 'Continue with KakaoTalk setup? [y/N] ' answer
[[ $answer =~ ^[Yy]$ ]] || exit 0

flatpak remote-add --user --if-not-exists flathub "$flathub_url"
flatpak install --user --noninteractive flathub "$app_id"
flatpak override --user \
  --env=XMODIFIERS=@im=fcitx \
  --env=RES_OPTIONS=single-request-reopen \
  --filesystem=xdg-download:rw \
  --filesystem=xdg-documents:rw \
  --filesystem=xdg-pictures:rw \
  "$app_id"

printf 'Checking the Bottles network path before creating the bottle.\n'
while true; do
  if kakaotalk-connectivity-check; then
    break
  fi

  cat >&2 <<'EOF'
KakaoTalk setup cannot continue until Bottles reaches its connectivity
endpoint from inside the Flatpak sandbox. Fix the reported DNS/network/WARP
condition, then retry this preflight. No bottle has been created or changed.
EOF
  read -r -p 'Retry Bottles connectivity now? [r/N] ' answer
  [[ $answer =~ ^[Rr]$ ]] ||
    die 'Bottles connectivity preflight did not pass; rerun kakaotalk-setup later'
done

readonly -a bottles_cli=(
  flatpak run
  --command=bottles-cli
  "$app_id"
)

profile_json=$(kakaotalk-profile current --json)
profile_id=$(jq -r '.id' <<<"$profile_json")
profile_runner=$(jq -r '.runner.name' <<<"$profile_json")
mapfile -t profile_dependencies < <(jq -r '.dependencies[].id' <<<"$profile_json")
((${#profile_dependencies[@]} > 0)) ||
  die 'the selected profile has no compatibility dependencies'
printf 'Installing the pinned KakaoTalk runner profile: %s\n' "$profile_id"
kakaotalk-profile install "$profile_id"

create_bottle_with_bottles_64_1() {
  local python_source

  python_source=$(
    cat <<'PYTHON'
# Bottles 64.1 dispatches repository callbacks through the GTK main loop even
# in bottles-cli, where no main loop runs. Deliver callbacks in their worker
# threads for this CLI-only process, then install each actually required
# component before calling Bottles' normal synchronous bottle builder.
import sys

sys.path.insert(1, "/app/share/bottles")

import gi

gi.require_version("Xdp", "1.0")

from gi.repository import Gio

from bottles.backend.state import EventManager, Events
from bottles.backend.utils.threading import RunAsync


original_run_async_init = RunAsync.__init__


def cli_run_async_init(self, *args, **kwargs):
    kwargs["callback_in_main_loop"] = False
    original_run_async_init(self, *args, **kwargs)


RunAsync.__init__ = cli_run_async_init

from bottles.backend.managers.manager import Manager
from bottles.frontend.params import APP_ID


def fail(message):
    print(f"kakaotalk-setup: {message}", file=sys.stderr)
    raise SystemExit(1)


name, environment, arch, runner = sys.argv[1:5]
manager = Manager(g_settings=Gio.Settings.new(APP_ID), is_cli=True)

print("Loading the Bottles component catalogs.", flush=True)
manager.organize_components()
EventManager.wait(Events.ComponentsOrganizing)
manager.organize_dependencies()
EventManager.wait(Events.DependenciesOrganizing)

if not manager.supported_wine_runners:
    fail("Bottles returned an empty Wine runner catalog")
if not manager.supported_dxvk:
    fail("Bottles returned an empty DXVK catalog")
if not manager.supported_vkd3d:
    fail("Bottles returned an empty VKD3D catalog")
if not manager.supported_dependencies:
    fail("Bottles returned an empty dependency catalog")

print("Installing a managed Wine runner if needed.", flush=True)
manager.check_runners()
print("Installing DXVK if needed.", flush=True)
manager.check_dxvk()
print("Installing VKD3D if needed.", flush=True)
manager.check_vkd3d()

manager.check_runners(False)
manager.check_dxvk(False)
manager.check_vkd3d(False)

if runner not in manager.runners_available:
    fail(f"the checksum-pinned runner is unavailable: {runner}")
if not manager.dxvk_available:
    fail("Bottles could not install DXVK")
if not manager.vkd3d_available:
    fail("Bottles could not install VKD3D")

result = manager.create_bottle(
    name=name,
    environment=environment,
    arch=arch,
    runner=runner,
    dxvk=manager.dxvk_available[0],
    vkd3d=manager.vkd3d_available[0],
    fn_logger=lambda message: print(message, flush=True),
)
if not result.ok:
    fail("Bottles failed while building the KakaoTalk bottle")
PYTHON
  )

  flatpak run --user --command=python3 "$app_id" \
    -c "$python_source" \
    "$bottle_name" application win64 "$profile_runner"
}

configure_kakaotalk_compatibility() {
  local python_source

  python_source=$(
    cat <<'PYTHON'
# Current KakaoTalk builds use Themida protection that exits with "Wrong DLL
# Present" on the Soda 9 runner. Select only the checksum-pinned runner from
# the managed profile and restore Wine's own graphics DLLs for this non-game
# bottle. Only uninstall components that are active so reruns stay safe.
import sys

sys.path.insert(1, "/app/share/bottles")

import gi

gi.require_version("Xdp", "1.0")

from gi.repository import Gio

from bottles.backend.managers.manager import Manager
from bottles.backend.wine.wineboot import WineBoot
from bottles.frontend.params import APP_ID


def fail(message):
    print(f"kakaotalk-setup: {message}", file=sys.stderr)
    raise SystemExit(1)


name, runner = sys.argv[1:3]
manager = Manager(g_settings=Gio.Settings.new(APP_ID), is_cli=True)
manager.check_bottles()
if name not in manager.local_bottles:
    fail("the KakaoTalk bottle could not be loaded")

config = manager.local_bottles[name]
for component in ("dxvk", "vkd3d"):
    if not getattr(config.Parameters, component):
        continue
    removed = manager.install_dll_component(
        config=config,
        component=component,
        remove=True,
    )
    if not removed.ok:
        fail(f"Bottles could not restore Wine DLLs while removing {component}")
    updated = manager.update_config(
        config=config,
        key=component,
        value=False,
        scope="Parameters",
    )
    if not updated.ok:
        fail(f"Bottles could not disable {component}")
    config = updated.data["config"]

manager.check_runners(False)
if runner not in manager.runners_available:
    fail(f"the pinned runner is unavailable: {runner}")
if config.Runner != runner:
    updated = manager.update_config(config=config, key="Runner", value=runner)
    if not updated.ok:
        fail(f"Bottles could not select the compatible runner {runner}")
    config = updated.data["config"]
    WineBoot(config).update()

updated = manager.update_config(
    config=config,
    key="use_steam_runtime",
    value=False,
    scope="Parameters",
)
if not updated.ok:
    fail("Bottles could not disable the Steam runtime for system Wine")

print(f"Using KakaoTalk-compatible runner: {runner}", flush=True)
PYTHON
  )

  flatpak run --user --command=python3 "$app_id" \
    -c "$python_source" \
    "$bottle_name" "$profile_runner"
}

configure_korean_bottle() {
  local python_source

  python_source=$(
    cat <<'PYTHON'
# Configure the dedicated KakaoTalk bottle for Korean UI. Keep the locale,
# font, and Windows registry state together so rerunning setup converges it.
import os
import shutil
import sys

sys.path.insert(1, "/app/share/bottles")

import gi

gi.require_version("Xdp", "1.0")

from bottles.backend.globals import Paths
from bottles.backend.models.config import BottleConfig
from bottles.backend.wine.reg import Reg, RegItem


def fail(message):
    print(f"kakaotalk-setup: {message}", file=sys.stderr)
    raise SystemExit(1)


name = sys.argv[1]
bottle_path = os.path.join(Paths.bottles, name)
config_path = os.path.join(bottle_path, "bottle.yml")
font_source = "/run/host/fonts/TTF/Pretendard-Regular.ttf"
font_name = "Pretendard-Regular.ttf"
font_destination = os.path.join(bottle_path, "drive_c", "windows", "Fonts", font_name)

loaded = BottleConfig.load(config_path)
if not loaded.ok:
    fail("the KakaoTalk bottle configuration could not be loaded")

config = loaded.data
config.Language = "ko_KR"
environment = dict(config.Environment_Variables or {})
environment.pop("WAYLAND_DISPLAY", None)
environment.update(
    {
        "LANG": "ko_KR.UTF-8",
        "LC_ALL": "ko_KR.UTF-8",
        "LC_CTYPE": "ko_KR.UTF-8",
    }
)
config.Environment_Variables = environment

saved = config.dump(config_path)
if not saved.ok:
    fail("the Korean language setting could not be saved")

if not os.path.isfile(font_source):
    fail("the managed Pretendard Korean font is unavailable inside Bottles")
os.makedirs(os.path.dirname(font_destination), exist_ok=True)
shutil.copyfile(font_source, font_destination)
os.chmod(font_destination, 0o644)

registry = []


def add(key, value, data):
    registry.append(RegItem(key=key, value=value, value_type="", data=data))


# Wine 10+ can otherwise select its native Wayland driver even when Bottles'
# Wayland toggle is off. KakaoTalk needs the mature X11/XWayland path for XIM
# Hangul composition, clipboard integration, and stable popup placement.
add(r"HKEY_CURRENT_USER\Software\Wine\Drivers", "Graphics", "x11")

# KakaoTalk mishandles Wine's default XIM callback preedit and can display
# composed Hangul one step behind the cursor. Wine's per-process root style
# leaves preedit rendering to Fcitx and sends only committed text to the app.
kakaotalk_x11 = (
    r"HKEY_CURRENT_USER\Software\Wine\AppDefaults\kakaotalk.exe\X11 Driver"
)
add(kakaotalk_x11, "InputStyle", "root")

international = r"HKEY_CURRENT_USER\Control Panel\International"
add(international, "Locale", "00000412")
add(international, "LocaleName", "ko-KR")
add(international, "sLanguage", "KOR")
add(international, "sCountry", "Korea")
add(international, "iCountry", "82")
add(international, "iDate", "2")
add(international, "iMeasure", "0")
add(international, "iPaperSize", "9")
add(international, "sDate", "-")
add(international, "sShortDate", "yyyy-MM-dd")
add(international, "sLongDate", "yyyy'년' M'월' d'일' dddd")
add(international, "sTimeFormat", "tt h:mm:ss")
add(international, "sShortTime", "tt h:mm")

geo = international + r"\Geo"
add(geo, "Name", "KR")
add(geo, "Nation", "134")
add(r"HKEY_CURRENT_USER\Keyboard Layout\Preload", "1", "00000412")
add(r"HKEY_CURRENT_USER\Software\Wine\Fonts", "Codepages", "949,949")

nls_language = r"HKEY_LOCAL_MACHINE\System\CurrentControlSet\Control\Nls\Language"
add(nls_language, "Default", "0412")
add(nls_language, "InstallLanguage", "0412")
nls_codepage = r"HKEY_LOCAL_MACHINE\System\CurrentControlSet\Control\Nls\CodePage"
add(nls_codepage, "ACP", "949")
add(nls_codepage, "OEMCP", "949")
add(nls_codepage, "MACCP", "10003")

windows_fonts = (
    r"HKEY_LOCAL_MACHINE\Software\Microsoft\Windows NT\CurrentVersion\Fonts"
)
add(windows_fonts, "Pretendard (TrueType)", font_name)

font_faces = (
    "Segoe UI",
    "Tahoma",
    "Malgun Gothic",
    "Malgun Gothic Semilight",
    "맑은 고딕",
    "Gulim",
    "GulimChe",
    "굴림",
    "굴림체",
    "Dotum",
    "DotumChe",
    "돋움",
    "돋움체",
)
wine_replacements = r"HKEY_CURRENT_USER\Software\Wine\Fonts\Replacements"
for face in font_faces:
    add(wine_replacements, face, "Pretendard")

font_substitutes = (
    r"HKEY_LOCAL_MACHINE\Software\Microsoft\Windows NT\CurrentVersion\FontSubstitutes"
)
for face in ("MS Shell Dlg", "MS Shell Dlg 2", *font_faces):
    add(font_substitutes, face, "Pretendard")

Reg(config).bulk_add(registry)
PYTHON
  )

  flatpak run --user --command=python3 "$app_id" \
    -c "$python_source" \
    "$bottle_name"
}

create_profile_snapshot() {
  local python_source

  python_source=$(
    cat <<'PYTHON'
import sys

sys.path.insert(1, "/app/share/bottles")

import gi

gi.require_version("Xdp", "1.0")

from gi.repository import Gio

from bottles.backend.managers.manager import Manager
from bottles.frontend.params import APP_ID


def fail(message):
    print(f"kakaotalk-setup: {message}", file=sys.stderr)
    raise SystemExit(1)


name, message = sys.argv[1:3]
manager = Manager(g_settings=Gio.Settings.new(APP_ID), is_cli=True)
manager.check_bottles()
if name not in manager.local_bottles:
    fail("the KakaoTalk bottle could not be loaded for snapshot creation")

result = manager.versioning_manager.create_state(
    config=manager.local_bottles[name],
    message=message,
)
if not result.status and result.message != "Nothing to commit":
    fail(result.message or "Bottles failed to create a recovery snapshot")

print(result.message or "An existing clean recovery snapshot is current.", flush=True)
PYTHON
  )

  flatpak run --user --command=python3 "$app_id" \
    -c "$python_source" \
    "$bottle_name" "Before enoshima profile $profile_id"
}

install_profile_dependencies() {
  local python_source

  python_source=$(
    cat <<'PYTHON'
import sys

sys.path.insert(1, "/app/share/bottles")

import gi

gi.require_version("Xdp", "1.0")

from gi.repository import Gio

from bottles.backend.state import EventManager, Events
from bottles.backend.utils.threading import RunAsync


original_run_async_init = RunAsync.__init__


def cli_run_async_init(self, *args, **kwargs):
    kwargs["callback_in_main_loop"] = False
    original_run_async_init(self, *args, **kwargs)


RunAsync.__init__ = cli_run_async_init

from bottles.backend.managers.manager import Manager
from bottles.frontend.params import APP_ID


def fail(message):
    print(f"kakaotalk-setup: {message}", file=sys.stderr)
    raise SystemExit(1)


name, *dependencies = sys.argv[1:]
manager = Manager(g_settings=Gio.Settings.new(APP_ID), is_cli=True)
manager.check_bottles()
if name not in manager.local_bottles:
    fail("the KakaoTalk bottle could not be loaded for dependency installation")

manager.organize_dependencies()
EventManager.wait(Events.DependenciesOrganizing)
config = manager.local_bottles[name]

for dependency in dependencies:
    if dependency in config.Installed_Dependencies:
        print(f"Dependency already installed: {dependency}", flush=True)
        continue
    manifest = manager.supported_dependencies.get(dependency)
    if manifest is None:
        fail(f"Bottles has no dependency manifest for {dependency}")
    result = manager.dependency_manager.install(config, [dependency, manifest])
    if not result.status:
        fail(result.message or f"Bottles failed to install {dependency}")
    print(f"Dependency installed: {dependency}", flush=True)
PYTHON
  )

  flatpak run --user --command=python3 "$app_id" \
    -c "$python_source" \
    "$bottle_name" "${profile_dependencies[@]}"
}

stop_existing_bottle() {
  if timeout --foreground --signal=TERM --kill-after=5s 20s \
    "${bottles_cli[@]}" shell -b "$bottle_name" -i \
    'taskkill /IM KakaoTalk.exe /T'; then
    flatpak kill "$app_id" 2>/dev/null || true
    return 0
  fi

  printf '%s\n' \
    'KakaoTalk did not stop within 20 seconds; stopping its Bottles sandbox.' >&2
  flatpak kill "$app_id" 2>/dev/null || true
}

bottles_json=$("${bottles_cli[@]}" --json list bottles)
if jq -e --arg name "$bottle_name" 'has($name)' >/dev/null <<<"$bottles_json"; then
  existing_arch=$(
    jq -r --arg name "$bottle_name" \
      '.[$name] as $b | if ($b | type) == "object" then ($b.Arch // $b.arch // "") else "" end' \
      <<<"$bottles_json"
  )
  existing_environment=$(
    jq -r --arg name "$bottle_name" \
      '.[$name] as $b | if ($b | type) == "object" then ($b.Environment // $b.environment // "") else "" end' \
      <<<"$bottles_json"
  )

  [[ -z $existing_arch || ${existing_arch,,} == win64 ]] ||
    die 'an existing KakaoTalk bottle is not win64; remove or rename it manually first'
  [[ -z $existing_environment || ${existing_environment,,} == application ]] ||
    die 'an existing KakaoTalk bottle is not an application bottle; remove or rename it manually first'

  printf 'Reusing the existing KakaoTalk bottle.\n'
  printf 'Stopping KakaoTalk before creating a private recovery snapshot.\n'
  stop_existing_bottle
  create_profile_snapshot
else
  printf 'Creating the dedicated KakaoTalk bottle. This may download a Wine runner.\n'
  bottles_version=$("${bottles_cli[@]}" --version)
  if [[ $bottles_version == 'Bottles 64.1' ]]; then
    create_bottle_with_bottles_64_1
  else
    "${bottles_cli[@]}" new \
      --bottle-name "$bottle_name" \
      --environment application \
      --arch win64
  fi

  bottles_json=$("${bottles_cli[@]}" --json list bottles)
  jq -e --arg name "$bottle_name" 'has($name)' >/dev/null <<<"$bottles_json" ||
    die 'Bottles did not report the newly created KakaoTalk bottle'
fi

printf 'Configuring the KakaoTalk Wine runner and graphics compatibility.\n'
configure_kakaotalk_compatibility

printf 'Configuring the KakaoTalk bottle for Korean text and locale.\n'
configure_korean_bottle

printf 'Installing the pinned KakaoTalk compatibility dependencies.\n'
install_profile_dependencies

# XIM is required for Hangul composition in Wine/XWayland. A 144-DPI Wine
# desktop matches the 1.5 compositor scale (96 * 1.5).
"${bottles_cli[@]}" edit \
  -b "$bottle_name" \
  --params wayland:false,custom_dpi:144 \
  --env-var XMODIFIERS=@im=fcitx
"${bottles_cli[@]}" reg add \
  -b "$bottle_name" \
  -k 'HKEY_CURRENT_USER\Control Panel\Desktop' \
  -v LogPixels \
  -d 144 \
  -t REG_DWORD
"${bottles_cli[@]}" reg add \
  -b "$bottle_name" \
  -k 'HKEY_CURRENT_USER\Control Panel\Desktop' \
  -v Win8DpiScaling \
  -d 1 \
  -t REG_DWORD

programs_json=$("${bottles_cli[@]}" --json programs -b "$bottle_name")
if ! jq -e --arg name "$program_name" \
  '[.[] | select(.name == $name)] | length > 0' \
  >/dev/null <<<"$programs_json"; then
  downloads_dir=$(xdg-user-dir DOWNLOAD 2>/dev/null || true)
  [[ -n $downloads_dir ]] || downloads_dir=$HOME/Downloads
  mkdir -p -- "$downloads_dir"
  installer_path=$downloads_dir/KakaoTalk_Setup_x64.exe

  printf 'Downloading the official KakaoTalk installer from:\n  %s\n' "$installer_url"
  curl \
    --fail \
    --location \
    --proto '=https' \
    --tlsv1.2 \
    --output "$installer_path" \
    "$installer_url"

  [[ $(LC_ALL=C head -c 2 -- "$installer_path") == MZ ]] || {
    rm -f -- "$installer_path"
    die 'the downloaded file is not a Windows executable'
  }

  printf 'Launching the installer. Complete it in the Wine window.\n'
  "${bottles_cli[@]}" run \
    -b "$bottle_name" \
    -e "$installer_path"

  read -r -p 'After the KakaoTalk installer has completely closed, press Enter to continue. '

  programs_json=$("${bottles_cli[@]}" --json programs -b "$bottle_name")
  candidate_path=$(
    jq -r '
      [
        .[]
        | select(
            (((.executable // "") | ascii_downcase) == "kakaotalk.exe")
            or (((.path // "") | ascii_downcase) | endswith("\\kakaotalk.exe"))
          )
      ][0].path // ""
    ' <<<"$programs_json"
  )

  if [[ -z $candidate_path ]]; then
    bottles_path=$("${bottles_cli[@]}" info bottles-path)
    candidate_path=$(find "$bottles_path/$bottle_name/drive_c" \
      -type f -ipath '*/Kakao/KakaoTalk/KakaoTalk.exe' -print -quit 2>/dev/null || true)
  fi
  if [[ -z $candidate_path ]]; then
    bottles_path=${bottles_path:-$("${bottles_cli[@]}" info bottles-path)}
    candidate_path=$(find "$bottles_path/$bottle_name/drive_c" \
      -type f -iname 'KakaoTalk.exe' -print -quit 2>/dev/null || true)
  fi

  [[ -n $candidate_path ]] ||
    die 'KakaoTalk.exe was not found; finish the installation, then rerun this helper'

  if ! jq -e --arg name "$program_name" \
    '[.[] | select(.name == $name)] | length > 0' \
    >/dev/null <<<"$programs_json"; then
    "${bottles_cli[@]}" add \
      -b "$bottle_name" \
      -n "$program_name" \
      -p "$candidate_path"
  fi
fi

programs_json=$("${bottles_cli[@]}" --json programs -b "$bottle_name")
jq -e --arg name "$program_name" \
  '[.[] | select(.name == $name)] | length > 0' \
  >/dev/null <<<"$programs_json" ||
  die 'KakaoTalk was installed but could not be registered as a Bottles program'

configured_bottles=$("${bottles_cli[@]}" --json list bottles)
jq -e \
  --arg name "$bottle_name" \
  --arg runner "$profile_runner" \
  --argjson required "$(jq -c '[.dependencies[].id]' <<<"$profile_json")" '
    .[$name] as $bottle
    | ($bottle.Runner // "") == $runner
      and ($bottle.Parameters.wayland == false)
      and ($bottle.Parameters.dxvk == false)
      and ($bottle.Parameters.vkd3d == false)
      and ($bottle.Environment_Variables.XMODIFIERS == "@im=fcitx")
      and ($bottle.Language == "ko_KR")
      and all($required[]; . as $dependency
        | ($bottle.Installed_Dependencies | index($dependency)) != null)
  ' >/dev/null <<<"$configured_bottles" ||
  die 'the KakaoTalk bottle did not converge to the selected profile'

registry_output=$("${bottles_cli[@]}" shell -b "$bottle_name" -i \
  'reg query "HKCU\Software\Wine\AppDefaults\kakaotalk.exe\X11 Driver" /v InputStyle')
grep -Eiq 'InputStyle[[:space:]]+REG_SZ[[:space:]]+root' \
  <<<"$registry_output" ||
  die 'the KakaoTalk InputStyle registry setting was not applied'

cat <<'EOF'

KakaoTalk setup is complete. Launch it from the app launcher with "KakaoTalk".

Before accepting a KakaoTalk update, open Bottles, select the KakaoTalk bottle,
and create a version/snapshot. Keep the bottle's working runner selected; do not
change it merely because a newer runner appears.

Run `kakaotalk-smoke-test` after login. The selected runner remains a candidate
until that report passes and `kakaotalk-profile promote` records it locally.
EOF
