#!/usr/bin/env bash
# shellcheck disable=SC2016 # jq programs intentionally use single quotes.
set -euo pipefail

readonly hyprctl_bin=${DESKTOP_DISPLAY_HYPRCTL:-hyprctl}
readonly jq_bin=${DESKTOP_DISPLAY_JQ:-jq}
readonly systemctl_bin=${DESKTOP_DISPLAY_SYSTEMCTL:-systemctl}
readonly qs_bin=${DESKTOP_DISPLAY_QS:-qs}
readonly route_bin=${DESKTOP_DISPLAY_ROUTE:-workspace-output-route}
readonly config_home=${DESKTOP_DISPLAY_CONFIG_HOME:-${XDG_CONFIG_HOME:-$HOME/.config}}
readonly state_home=${DESKTOP_DISPLAY_STATE_HOME:-${XDG_STATE_HOME:-$HOME/.local/state}}
readonly runtime_home=${DESKTOP_DISPLAY_RUNTIME_HOME:-${XDG_RUNTIME_DIR:-}}
readonly defaults_file=${DESKTOP_DISPLAY_DEFAULTS_FILE:-$config_home/enoshima/defaults/display.json}
readonly user_dir=$config_home/enoshima/user/display-topologies
readonly state_dir=$state_home/enoshima/display
readonly runtime_dir=$runtime_home/enoshima/display
readonly pending_file=$runtime_dir/pending.json
readonly lock_file=$runtime_dir/controller.lock

die() {
  printf 'desktop-display-mode: %s\n' "$*" >&2
  exit 1
}

usage() {
  cat >&2 <<'EOF'
usage: desktop-display-mode menu
       desktop-display-mode status --json
       desktop-display-mode list --json
       desktop-display-mode apply {internal|extend|mirror|external}
       desktop-display-mode apply-profile {balanced|matched}
       desktop-display-mode confirm
       desktop-display-mode revert
       desktop-display-mode reconcile
       desktop-display-mode identify
       desktop-display-mode import-current
       desktop-display-mode doctor
EOF
  exit 2
}

if [[ ${1:-} == menu ]]; then
  exec "$qs_bin" -p "$config_home/quickshell/cyberdock" \
    ipc call -- display toggle
fi

command -v "$hyprctl_bin" >/dev/null 2>&1 || die "hyprctl command not found: $hyprctl_bin"
command -v "$jq_bin" >/dev/null 2>&1 || die "jq command not found: $jq_bin"
command -v flock >/dev/null 2>&1 || die 'flock is required'
[[ -n $runtime_home && $runtime_home == /* ]] || die 'XDG_RUNTIME_DIR must be absolute'
[[ -f $defaults_file && ! -L $defaults_file ]] || die "managed defaults are missing: $defaults_file"
defaults=$("$jq_bin" -c -e '
  select(
    .schema == 2
    and .display_policy_revision == 2
    and (.internal_output | type == "string")
    and (.known_external_description_pattern | type == "string")
    and (.confirmation_timeout_seconds | type == "number")
    and .confirmation_timeout_seconds >= 5
    and (.default_profile | type == "string")
    and (.fallback_external_scale | type == "string" or type == "number")
    and (.profiles | type == "object")
    and (.profiles[.default_profile] | type == "object")
    and all(.profiles[];
      (.internal_scale | type == "number")
      and (.internal_position | type == "string")
      and (.known_external_scale | type == "number")
      and (.known_external_position | type == "string"))
  )
' "$defaults_file") || die 'managed display defaults are invalid'

for directory in "$user_dir" "$state_dir" "$runtime_dir"; do
  [[ ! -L $directory ]] || die "$directory must not be a symbolic link"
  install -d -m 0700 "$directory"
  chmod 0700 "$directory"
done

exec 9>"$lock_file"
chmod 0600 "$lock_file"
flock -x 9

internal_output=$("$jq_bin" -r '.internal_output' <<<"$defaults")
known_external_pattern=$("$jq_bin" -r '.known_external_description_pattern' <<<"$defaults")
confirm_timeout=$("$jq_bin" -r '.confirmation_timeout_seconds | floor' <<<"$defaults")
default_profile=$("$jq_bin" -r '.default_profile' <<<"$defaults")
fallback_external_scale=$("$jq_bin" -r '.fallback_external_scale' <<<"$defaults")
policy_revision=$("$jq_bin" -r '.display_policy_revision' <<<"$defaults")

profile_value() {
  local profile=$1 key=$2
  "$jq_bin" -r --arg profile "$profile" --arg key "$key" \
    '.profiles[$profile][$key] // empty' <<<"$defaults"
}

valid_profile() {
  "$jq_bin" -e --arg profile "$1" '.profiles[$profile] != null' \
    <<<"$defaults" >/dev/null
}

monitors_all() {
  local output
  output=$("$hyprctl_bin" -j monitors all) || die 'Hyprland monitor query failed'
  "$jq_bin" -c -e 'select(type == "array")' <<<"$output" ||
    die 'Hyprland returned invalid monitor JSON'
}

active_monitors() {
  "$jq_bin" -c '[.[] | select((.disabled // false) == false and (.width // 0) > 0)]'
}

valid_output() {
  [[ $1 =~ ^[A-Za-z0-9_.:-]+$ ]]
}

topology_hash() {
  local monitors=$1
  "$jq_bin" -c '
    [
      .[]
      | select((.name // "") != "")
      | [(.make // ""), (.model // ""), (.serial // .serialNumber // ""), (.description // "")]
      | join("|")
    ] | sort
  ' <<<"$monitors" | sha256sum | awk '{print $1}'
}

capture_snapshot() {
  local monitors=$1 captured_at
  captured_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  "$jq_bin" -c --arg capturedAt "$captured_at" \
    --argjson policyRevision "$policy_revision" '
    {
      schema: 2,
      policy_revision: $policyRevision,
      captured_at: $capturedAt,
      monitors: [
        .[]
        | select((.disabled // false) == false and (.width // 0) > 0)
        | {
            name,
            mode: ((.width | tostring) + "x" + (.height | tostring)
              + "@" + ((.refreshRate // 60) | tostring)),
            position: ((.x // 0 | tostring) + "x" + (.y // 0 | tostring)),
            scale: (.scale // 1),
            transform: (.transform // 0),
            mirror: (.mirrorOf // "none"),
            fingerprint: ([
              (.make // ""),
              (.model // ""),
              (.serial // .serialNumber // ""),
              (.description // "")
            ] | join("|"))
          }
      ]
    }
  ' <<<"$monitors"
}

write_json() {
  local destination=$1 content=$2 directory temporary
  directory=$(dirname -- "$destination")
  temporary=$(mktemp "$directory/.display-state.XXXXXX")
  chmod 0600 "$temporary"
  printf '%s\n' "$content" >"$temporary"
  sync -f "$temporary" 2>/dev/null || true
  mv -f -- "$temporary" "$destination"
}

rule_for_monitor() {
  local name=$1 mode=$2 position=$3 scale=$4 transform=${5:-0} mirror=${6:-none}
  valid_output "$name" || die "unsafe output name: $name"
  [[ $mode =~ ^(preferred|highres|highrr|maxwidth|[0-9]+x[0-9]+@[0-9.]+)$ ]] ||
    die "unsafe output mode: $mode"
  [[ $position =~ ^(auto(-right|-left|-up|-down)?|[-0-9]+x[-0-9]+)$ ]] ||
    die "unsafe output position: $position"
  [[ $scale =~ ^(auto|[0-9]+([.][0-9]+)?)$ ]] || die "unsafe output scale: $scale"
  [[ $transform =~ ^[0-7]$ ]] || die "unsafe output transform: $transform"
  printf '%s,%s,%s,%s,transform,%s,bitdepth,8,cm,srgb' \
    "$name" "$mode" "$position" "$scale" "$transform"
  if [[ $mirror != none ]]; then
    valid_output "$mirror" || die "unsafe mirror source: $mirror"
    printf ',mirror,%s' "$mirror"
  fi
}

apply_rule() {
  "$hyprctl_bin" keyword monitor "$1" >/dev/null
}

apply_batch() {
  local batch='' rule
  (($# > 0)) || return 0
  for rule in "$@"; do
    batch+="keyword monitor $rule;"
  done
  "$hyprctl_bin" --batch "$batch" >/dev/null
}

managed_rule() {
  local monitor=$1 position=$2 scale=$3
  "$jq_bin" -r \
    --arg position "$position" \
    --arg scale "$scale" '
      if (.disabled // false) == false and (.width // 0) > 0 then
        [
          .name,
          ((.width | tostring) + "x" + (.height | tostring)
            + "@" + ((.refreshRate // 60) | tostring)),
          $position,
          $scale,
          ((.transform // 0) | tostring)
        ] | @tsv
      else
        [.name, "preferred", $position, $scale, "0"] | @tsv
      end
    ' <<<"$monitor"
}

is_known_external() {
  local monitor=$1
  "$jq_bin" -e --arg pattern "$known_external_pattern" \
    '((.description // "") | test($pattern; "i"))' <<<"$monitor" >/dev/null
}

apply_managed_extend() {
  local profile=$1 monitors=$2 internal external row name mode position scale transform
  local internal_position internal_scale known_position known_scale has_known=false
  local -a target_rules=()

  valid_profile "$profile" || die "unknown display profile: $profile"
  internal=$("$jq_bin" -c -e --arg internal "$internal_output" \
    '.[] | select(.name == $internal)' <<<"$monitors") ||
    die "internal output is not connected: $internal_output"
  internal_position=$(profile_value "$profile" internal_position)
  internal_scale=$(profile_value "$profile" internal_scale)
  known_position=$(profile_value "$profile" known_external_position)
  known_scale=$(profile_value "$profile" known_external_scale)

  while IFS= read -r row; do
    [[ -n $row ]] || continue
    external=$("$jq_bin" -c -e --arg name "$row" \
      '.[] | select(.name == $name)' <<<"$monitors")
    if is_known_external "$external"; then
      has_known=true
      break
    fi
  done < <("$jq_bin" -r --arg internal "$internal_output" \
    '.[] | select(.name != $internal) | .name' <<<"$monitors")

  [[ $("$jq_bin" -r --arg internal "$internal_output" \
    '[.[] | select(.name != $internal)] | length' <<<"$monitors") -gt 0 ]] ||
    die 'no external output is connected'
  if [[ $has_known != true ]]; then
    internal_position=0x0
  fi
  IFS=$'\t' read -r name mode position scale transform < <(
    managed_rule "$internal" "$internal_position" "$internal_scale"
  )
  target_rules+=("$(rule_for_monitor "$name" "$mode" "$position" "$scale" "$transform")")

  while IFS= read -r row; do
    [[ -n $row ]] || continue
    external=$("$jq_bin" -c -e --arg name "$row" \
      '.[] | select(.name == $name)' <<<"$monitors")
    position=auto-right
    scale=$fallback_external_scale
    if is_known_external "$external"; then
      position=$known_position
      scale=$known_scale
    fi
    IFS=$'\t' read -r name mode position scale transform < <(
      managed_rule "$external" "$position" "$scale"
    )
    target_rules+=("$(rule_for_monitor "$name" "$mode" "$position" "$scale" "$transform")")
  done < <("$jq_bin" -r --arg internal "$internal_output" \
    '.[] | select(.name != $internal) | .name' <<<"$monitors")
  apply_batch "${target_rules[@]}"
}

common_mirror_mode() {
  local internal=$1 external=$2
  "$jq_bin" -nr --argjson internal "$internal" --argjson external "$external" '
    def modes($monitor):
      [
        ($monitor.availableModes // [])[]
        | capture("^(?<width>[0-9]+)x(?<height>[0-9]+)@(?<refresh>[0-9.]+)")
        | .width |= tonumber
        | .height |= tonumber
        | .refresh |= tonumber
        | .refresh_key = ((.refresh * 100 | round) / 100)
      ];
    modes($internal) as $left
    | modes($external) as $right
    | [
        $left[] as $candidate
        | select(any($right[];
            .width == $candidate.width
            and .height == $candidate.height
            and ((.refresh_key - $candidate.refresh_key) | fabs) < 0.02))
        | $candidate
        | .area = (.width * .height)
      ]
    | sort_by(.area, .refresh)
    | last
    | if . == null then empty
      else ((.width | tostring) + "x" + (.height | tostring) + "@" + (.refresh | tostring))
      end
  '
}

mode_from_monitors() {
  local monitors=$1
  "$jq_bin" -r --arg internal "$internal_output" '
    [ .[] | select((.disabled // false) == false and (.width // 0) > 0) ] as $active
    | if ($active | length) == 0 then "none"
      elif any($active[]; (.mirrorOf // "none") != "none") then "mirror"
      elif ($active | length) > 1 then "extend"
      elif $active[0].name == $internal then "internal"
      else "external"
      end
  ' <<<"$monitors"
}

verify_mode() {
  local expected=$1 current
  current=$(mode_from_monitors "$(monitors_all)")
  [[ $current == "$expected" ]] || {
    printf 'desktop-display-mode: expected %s, Hyprland reports %s\n' "$expected" "$current" >&2
    return 1
  }
}

restore_snapshot() {
  local snapshot=$1 current_json row name mode position scale transform mirror fingerprint mapped_name
  local -a enable_rules=() disable_rules=() restored_names=()
  current_json=$(monitors_all)

  while IFS=$'\t' read -r name mode position scale transform mirror fingerprint; do
    [[ -n $name ]] || continue
    mapped_name=$("$jq_bin" -r --arg fingerprint "$fingerprint" --arg name "$name" '
      def fingerprint: [
        (.make // ""),
        (.model // ""),
        (.serial // .serialNumber // ""),
        (.description // "")
      ] | join("|");
      (map(select(fingerprint == $fingerprint))[0].name
        // map(select(.name == $name))[0].name
        // "")
    ' <<<"$current_json")
    [[ -n $mapped_name ]] || die "saved output is no longer connected: $name"
    if [[ $mirror != none ]]; then
      mirror=$("$jq_bin" -r --arg mirror "$mirror" '
        (.monitors | map(select(.name == $mirror))[0] // null) as $saved
        | if $saved == null then $mirror
          else ($saved.fingerprint // $mirror)
          end
      ' <<<"$snapshot")
      mirror=$("$jq_bin" -r --arg fingerprint "$mirror" --arg name "$mirror" '
        def fingerprint: [
          (.make // ""),
          (.model // ""),
          (.serial // .serialNumber // ""),
          (.description // "")
        ] | join("|");
        (map(select(fingerprint == $fingerprint))[0].name
          // map(select(.name == $name))[0].name
          // "")
      ' <<<"$current_json")
      [[ -n $mirror ]] || die 'saved mirror source is no longer connected'
    fi
    restored_names+=("$mapped_name")
    enable_rules+=("$(rule_for_monitor "$mapped_name" "$mode" "$position" "$scale" "$transform" "$mirror")")
  done < <("$jq_bin" -r '.monitors[] | [.name,.mode,.position,(.scale|tostring),(.transform|tostring),.mirror,.fingerprint] | @tsv' <<<"$snapshot")
  ((${#enable_rules[@]} > 0)) || die 'refusing to restore a snapshot with no active outputs'
  apply_batch "${enable_rules[@]}"

  while IFS= read -r name; do
    [[ -n $name ]] || continue
    found=false
    for row in "${restored_names[@]}"; do
      [[ $row == "$name" ]] && found=true
    done
    if [[ $found == false ]]; then
      disable_rules+=("$name,disable")
    fi
  done < <("$jq_bin" -r '.[].name' <<<"$current_json")
  apply_batch "${disable_rules[@]}"
  "$route_bin" >/dev/null 2>&1 || true
}

save_profile() {
  local monitors=$1 mode=$2 selected_profile=${3:-custom} topology profile
  topology=$(topology_hash "$monitors")
  profile=$(capture_snapshot "$monitors" | "$jq_bin" -c \
    --arg topology "$topology" --arg mode "$mode" --arg profile "$selected_profile" \
    '. + {topology: $topology, mode: $mode, profile: $profile}')
  write_json "$user_dir/$topology.json" "$profile"
}

legacy_managed_default() {
  local profile=$1
  "$jq_bin" -e --arg internal "$internal_output" --arg external "$known_external_pattern" '
    select(.schema == 1)
    | if .mode == "internal" then
        (.monitors | length) == 1
        and any(.monitors[];
          .name == $internal
          and (.scale == 1.5)
          and (.position == "0x0"))
      elif .mode == "extend" then
        (.monitors | length) == 2
        and any(.monitors[];
          .name == $internal
          and (.mode | startswith("2880x1800@"))
          and (.position == "0x240")
          and (.scale == 1.5))
        and any(.monitors[];
          ((.fingerprint // "") | test($external; "i"))
          and (.mode | startswith("3840x2160@"))
          and (.position == "1920x0")
          and (.scale == 1.5))
      else false
      end
  ' <<<"$profile" >/dev/null
}

arm_revert() {
  "$systemctl_bin" --user restart desktop-display-revert.timer >/dev/null 2>&1
}

cancel_revert() {
  "$systemctl_bin" --user stop desktop-display-revert.timer >/dev/null 2>&1 || true
}

apply_mode() {
  local target=$1 require_confirmation=${2:-true} selected_profile=${3:-$default_profile}
  local monitors internal external mirror_mode snapshot topology transaction deadline pending
  local row name mode position scale transform external_scale
  local -a connected_names=() externals=() target_rules=() disable_rules=()

  monitors=$(monitors_all)
  snapshot=$(capture_snapshot "$monitors")
  internal=$("$jq_bin" -c -e --arg internal "$internal_output" '.[] | select(.name == $internal)' <<<"$monitors") ||
    die "internal output is not connected: $internal_output"
  mapfile -t connected_names < <("$jq_bin" -r '.[].name' <<<"$monitors")
  mapfile -t externals < <("$jq_bin" -r --arg internal "$internal_output" '.[] | select(.name != $internal) | .name' <<<"$monitors")
  external=$("$jq_bin" -c --arg internal "$internal_output" '[.[] | select(.name != $internal)][0] // empty' <<<"$monitors")

  case $target in
    internal)
      valid_profile "$selected_profile" || die "unknown display profile: $selected_profile"
      scale=$(profile_value "$selected_profile" internal_scale)
      IFS=$'\t' read -r name mode position scale transform < <(managed_rule "$internal" 0x0 "$scale")
      apply_rule "$(rule_for_monitor "$name" "$mode" 0x0 "$scale" "$transform")"
      for name in "${externals[@]}"; do disable_rules+=("$name,disable"); done
      apply_batch "${disable_rules[@]}"
      ;;
    external)
      [[ -n $external ]] || die 'no external output is connected'
      valid_profile "$selected_profile" || die "unknown display profile: $selected_profile"
      external_scale=$fallback_external_scale
      if is_known_external "$external"; then
        external_scale=$(profile_value "$selected_profile" known_external_scale)
      fi
      IFS=$'\t' read -r name mode position scale transform < <(managed_rule "$external" 0x0 "$external_scale")
      apply_rule "$(rule_for_monitor "$name" "$mode" 0x0 "$scale" "$transform")"
      for row in "${connected_names[@]}"; do
        [[ $row == "$name" ]] || disable_rules+=("$row,disable")
      done
      apply_batch "${disable_rules[@]}"
      ;;
    extend)
      apply_managed_extend "$selected_profile" "$monitors"
      ;;
    mirror)
      [[ -n $external ]] || die 'no external output is connected'
      mirror_mode=$(common_mirror_mode "$internal" "$external")
      [[ -n $mirror_mode ]] || die 'no compatible duplicate mode exists'
      external_name=$("$jq_bin" -r '.name' <<<"$external")
      apply_rule "$(rule_for_monitor "$internal_output" "$mirror_mode" 0x0 1 0)"
      target_rules+=("$(rule_for_monitor "$external_name" "$mirror_mode" 0x0 1 0 "$internal_output")")
      for row in "${externals[@]:1}"; do disable_rules+=("$row,disable"); done
      apply_batch "${target_rules[@]}" "${disable_rules[@]}"
      ;;
    *) die "unknown display mode: $target" ;;
  esac

  if ! verify_mode "$target"; then
    restore_snapshot "$snapshot"
    die 'display mode verification failed; the previous layout was restored'
  fi
  "$route_bin" >/dev/null 2>&1 || true

  if [[ $require_confirmation == true ]]; then
    snapshot=$(capture_snapshot "$monitors")
    topology=$(topology_hash "$monitors")
    transaction="$(date +%s)-$$"
    deadline=$(($(date +%s) + confirm_timeout))
    pending=$("$jq_bin" -c -n \
      --arg transaction "$transaction" \
      --arg target "$target" \
      --arg topology "$topology" \
      --arg profile "$selected_profile" \
      --argjson deadline "$deadline" \
      --argjson snapshot "$snapshot" \
      '{schema:2,transaction:$transaction,target_mode:$target,target_profile:$profile,topology:$topology,deadline:$deadline,snapshot:$snapshot}')
    write_json "$pending_file" "$pending"
    if ! arm_revert; then
      restore_snapshot "$snapshot"
      rm -f -- "$pending_file"
      die 'failed to arm automatic rollback; the previous layout was restored'
    fi
  fi
}

status_command() {
  local monitors mode topology pending=null now remaining=0 external_count
  monitors=$(monitors_all)
  mode=$(mode_from_monitors "$monitors")
  topology=$(topology_hash "$monitors")
  external_count=$("$jq_bin" -r --arg internal "$internal_output" \
    '[.[] | select(.name != $internal)] | length' <<<"$monitors")
  if [[ -f $pending_file && ! -L $pending_file ]]; then
    pending=$("$jq_bin" -c -e 'select((.schema == 1 or .schema == 2) and (.snapshot.monitors | length > 0))' "$pending_file" 2>/dev/null || printf null)
    if [[ $pending != null ]]; then
      now=$(date +%s)
      remaining=$(($("$jq_bin" -r '.deadline' <<<"$pending") - now))
      ((remaining > 0)) || remaining=0
    fi
  fi
  "$jq_bin" -c -n --arg mode "$mode" --arg topology "$topology" \
    --arg defaultProfile "$default_profile" \
    --argjson remaining "$remaining" --argjson pending "$pending" \
    --argjson externalCount "$external_count" \
    '{schema:2,mode:$mode,topology:$topology,pending:($pending != null),seconds_remaining:$remaining,target_mode:($pending.target_mode // null),target_profile:($pending.target_profile // null),default_profile:$defaultProfile,external_count:$externalCount}'
}

case ${1:-} in
  status)
    [[ $# -eq 2 && $2 == --json ]] || usage
    status_command
    ;;
  list)
    [[ $# -eq 2 && $2 == --json ]] || usage
    monitors=$(monitors_all)
    external_count=$("$jq_bin" -r --arg internal "$internal_output" '[.[] | select(.name != $internal)] | length' <<<"$monitors")
    "$jq_bin" -c -n --argjson externalCount "$external_count" \
      --arg defaultProfile "$default_profile" \
      --argjson profiles "$("$jq_bin" -c '[.profiles | keys[]]' <<<"$defaults")" \
      '{schema:2,default_profile:$defaultProfile,profiles:$profiles,modes:[
        {id:"internal",available:true},
        {id:"mirror",available:($externalCount > 0)},
        {id:"extend",available:($externalCount > 0)},
        {id:"external",available:($externalCount > 0)}
      ]}'
    ;;
  apply)
    [[ $# -eq 2 ]] || usage
    apply_mode "$2" true "$default_profile"
    ;;
  apply-profile)
    [[ $# -eq 2 ]] || usage
    valid_profile "$2" || die "unknown display profile: $2"
    apply_mode extend true "$2"
    ;;
  confirm)
    [[ $# -eq 1 ]] || usage
    [[ -f $pending_file && ! -L $pending_file ]] || exit 0
    pending=$("$jq_bin" -c -e 'select(.schema == 1 or .schema == 2)' "$pending_file") || die 'pending transaction is invalid'
    save_profile "$(monitors_all)" \
      "$("$jq_bin" -r '.target_mode' <<<"$pending")" \
      "$("$jq_bin" -r '.target_profile // "custom"' <<<"$pending")"
    rm -f -- "$pending_file"
    cancel_revert
    ;;
  revert)
    [[ $# -eq 1 ]] || usage
    [[ -f $pending_file && ! -L $pending_file ]] || exit 0
    pending=$("$jq_bin" -c -e 'select((.schema == 1 or .schema == 2) and (.snapshot.monitors | length > 0))' "$pending_file") ||
      die 'pending transaction is invalid'
    restore_snapshot "$("$jq_bin" -c '.snapshot' <<<"$pending")"
    rm -f -- "$pending_file"
    cancel_revert
    ;;
  reconcile)
    [[ $# -eq 1 ]] || usage
    [[ ! -f $pending_file ]] || exit 0
    monitors=$(monitors_all)
    topology=$(topology_hash "$monitors")
    profile=$user_dir/$topology.json
    if [[ -f $profile && ! -L $profile ]]; then
      profile_json=$("$jq_bin" -c -e 'select((.schema == 1 or .schema == 2) and (.monitors | length > 0))' "$profile") || exit 0
      mode=$("$jq_bin" -r '.mode' <<<"$profile_json")
      snapshot=$(capture_snapshot "$monitors")
      if legacy_managed_default "$profile_json"; then
        apply_mode "$mode" false "$default_profile"
        save_profile "$(monitors_all)" "$mode" "$default_profile"
      else
        restore_snapshot "$("$jq_bin" -c '{schema,policy_revision,monitors}' <<<"$profile_json")"
      fi
      if ! verify_mode "$mode"; then
        restore_snapshot "$snapshot"
        die 'saved topology verification failed; the current layout was restored'
      fi
    else
      "$route_bin" >/dev/null 2>&1 || true
    fi
    ;;
  identify)
    [[ $# -eq 1 ]] || usage
    monitors=$(monitors_all)
    while IFS=$'\t' read -r name description; do
      "$hyprctl_bin" notify -1 3500 'rgb(62d8ff)' "[$name] $description" >/dev/null || true
    done < <("$jq_bin" -r '.[] | [.name, (.description // .name)] | @tsv' <<<"$monitors")
    ;;
  import-current)
    [[ $# -eq 1 ]] || usage
    monitors=$(monitors_all)
    save_profile "$monitors" "$(mode_from_monitors "$monitors")" custom
    ;;
  doctor)
    [[ $# -eq 1 ]] || usage
    monitors=$(monitors_all)
    printf 'Hyprland: %s\n' "$("$hyprctl_bin" version | head -n1)"
    printf 'Topology: %s\n' "$(topology_hash "$monitors")"
    printf 'Current mode: %s\n' "$(mode_from_monitors "$monitors")"
    "$jq_bin" -r '.[] | "- \(.name): \(.description // "unknown") [\(if (.disabled // false) then "disabled" else "active" end)]"' <<<"$monitors"
    ;;
  *) usage ;;
esac
