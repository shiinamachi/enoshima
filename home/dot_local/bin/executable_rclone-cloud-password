#!/usr/bin/env bash

# Print the rclone configuration password directly from GNOME Keyring. This
# helper is used through rclone's --password-command interface so the secret is
# never embedded in a systemd unit or exported into the long-running process.
set -euo pipefail

secret=
if ! secret=$(
  /usr/bin/secret-tool lookup \
    application enoshima \
    purpose rclone-config 2>/dev/null
); then
  legacy_secret=$(
    /usr/bin/secret-tool lookup \
      application my-arch-configurations \
      purpose rclone-config
  ) || {
    printf 'rclone-cloud-password: GNOME Keyring is locked or the rclone secret is missing\n' >&2
    exit 1
  }

  [[ -n $legacy_secret ]] || {
    printf 'rclone-cloud-password: GNOME Keyring returned an empty legacy rclone secret\n' >&2
    exit 1
  }
  if ! printf '%s' "$legacy_secret" |
    /usr/bin/secret-tool store \
      --label='enoshima rclone config' \
      application enoshima \
      purpose rclone-config; then
    unset legacy_secret
    printf 'rclone-cloud-password: could not migrate the rclone secret to enoshima\n' >&2
    exit 1
  fi
  secret=$(
    /usr/bin/secret-tool lookup \
      application enoshima \
      purpose rclone-config
  ) || {
    unset legacy_secret
    printf 'rclone-cloud-password: could not verify the migrated enoshima rclone secret\n' >&2
    exit 1
  }
  [[ $secret == "$legacy_secret" ]] || {
    unset legacy_secret secret
    printf 'rclone-cloud-password: migrated rclone secret verification failed\n' >&2
    exit 1
  }
  /usr/bin/secret-tool clear \
    application my-arch-configurations \
    purpose rclone-config >/dev/null 2>&1 || true
  unset legacy_secret
fi

[[ -n $secret ]] || {
  printf 'rclone-cloud-password: GNOME Keyring returned an empty rclone secret\n' >&2
  exit 1
}

printf '%s\n' "$secret"
