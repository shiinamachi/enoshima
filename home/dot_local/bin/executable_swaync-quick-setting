#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf 'Usage: %s {apply|status} {wifi|bluetooth|night-light}\n' "${0##*/}" >&2
  exit 64
}

[[ $# == 2 ]] || usage
operation=$1
setting=$2
quick_setting_timeout=${ENOSHIMA_QUICK_SETTING_TIMEOUT_SECONDS:-5}

if [[ ! $quick_setting_timeout =~ ^[1-9][0-9]?$ ]]; then
  printf 'ENOSHIMA_QUICK_SETTING_TIMEOUT_SECONDS must be between 1 and 99\n' >&2
  exit 64
fi

run_bounded() {
  /usr/bin/timeout \
    --signal=TERM \
    --kill-after=1s \
    "${quick_setting_timeout}s" \
    "$@"
}

status() {
  case $setting in
    wifi)
      if [[ $(LC_ALL=C run_bounded nmcli radio wifi 2>/dev/null) == enabled ]]; then
        printf 'true\n'
      else
        printf 'false\n'
      fi
      ;;
    bluetooth)
      if LC_ALL=C run_bounded bluetoothctl show 2>/dev/null |
        grep -Fq 'Powered: yes'; then
        printf 'true\n'
      else
        printf 'false\n'
      fi
      ;;
    night-light)
      if run_bounded systemctl --user is-active --quiet \
        hyprsunset-quick.service 2>/dev/null; then
        printf 'true\n'
      else
        printf 'false\n'
      fi
      ;;
    *) usage ;;
  esac
}

apply() {
  case ${SWAYNC_TOGGLE_STATE:-} in
    true) enabled=true ;;
    false) enabled=false ;;
    *)
      printf 'SWAYNC_TOGGLE_STATE must be true or false\n' >&2
      exit 64
      ;;
  esac

  case $setting in
    wifi)
      if [[ $enabled == true ]]; then
        run_bounded nmcli radio wifi on
      else
        run_bounded nmcli radio wifi off
      fi
      ;;
    bluetooth)
      if [[ $enabled == true ]]; then
        run_bounded bluetoothctl power on
      else
        run_bounded bluetoothctl power off
      fi
      ;;
    night-light)
      if [[ $enabled == true ]]; then
        run_bounded systemctl --user start hyprsunset-quick.service
      else
        run_bounded systemctl --user stop hyprsunset-quick.service
      fi
      ;;
    *) usage ;;
  esac
}

case $operation in
  apply) apply ;;
  status) status ;;
  *) usage ;;
esac
