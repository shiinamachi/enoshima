#!/usr/bin/env bash
set -euo pipefail

hyprctl_bin=${WORKSPACE_OUTPUT_ROUTE_HYPRCTL:-hyprctl}
jq_bin=${WORKSPACE_OUTPUT_ROUTE_JQ:-jq}

monitors=$($hyprctl_bin monitors -j)
workspaces=$($hyprctl_bin workspaces -j)

internal_output=$(
  $jq_bin -r 'map(select(.name == "eDP-1"))[0].name // empty' <<<"$monitors"
)
[[ -n $internal_output ]] || exit 0

mapfile -t external_outputs < <(
  # `$internal` is a jq variable supplied by --arg, not a shell expansion.
  # shellcheck disable=SC2016
  $jq_bin -r --arg internal "$internal_output" '
    map(select(
      .name != $internal
      and (.disabled // false) == false
      and (.mirrorOf // "none") == "none"
    ))
    | sort_by(.x // 0, .y // 0, .name)
    | .[].name
  ' <<<"$monitors"
)

external_workspace_ids=(1 2 4)
internal_workspace_ids=(3 5 6 7 8 9 10)

move_workspace() {
  local id=$1
  local target_output=$2
  local current_output

  current_output=$(
    # `$id` is a jq variable supplied by --argjson, not a shell expansion.
    # shellcheck disable=SC2016
    $jq_bin -r --argjson id "$id" \
      'map(select(.id == $id))[0].monitor // empty' <<<"$workspaces"
  )

  [[ $current_output == "$target_output" ]] && return 0
  [[ $target_output =~ ^[[:alnum:]_.-]+$ ]] || return 1
  $hyprctl_bin dispatch \
    "hl.dsp.workspace.move({ workspace = $id, monitor = \"$target_output\" })" \
    >/dev/null
}

if ((${#external_outputs[@]} > 0)); then
  for index in "${!external_workspace_ids[@]}"; do
    id=${external_workspace_ids[$index]}
    output=${external_outputs[$((index % ${#external_outputs[@]}))]}
    move_workspace "$id" "$output"
  done
else
  for id in "${external_workspace_ids[@]}"; do
    move_workspace "$id" "$internal_output"
  done
fi

for id in "${internal_workspace_ids[@]}"; do
  move_workspace "$id" "$internal_output"
done
