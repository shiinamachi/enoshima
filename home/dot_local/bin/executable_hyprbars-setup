#!/usr/bin/env bash
set -euo pipefail

readonly plugin_repository=https://github.com/hyprwm/hyprland-plugins
state_home=${XDG_STATE_HOME:-$HOME/.local/state}
state_dir=$state_home/hyprbars
abi_marker=$state_dir/hyprland-abi

die() {
  printf 'hyprbars-setup: %s\n' "$*" >&2
  exit 1
}

current_abi() {
  hyprctl version -j | jq -er '.abiHash'
}

notify_rebuild() {
  local message=$1
  if command -v notify-send >/dev/null 2>&1; then
    notify-send --urgency=normal 'Hyprbars needs attention' "$message" || true
  fi
  printf 'hyprbars-setup: %s\n' "$message" >&2
}

command -v hyprctl >/dev/null 2>&1 || die 'hyprctl is not installed'
command -v hyprpm >/dev/null 2>&1 || die 'hyprpm is not installed'
command -v jq >/dev/null 2>&1 || die 'jq is not installed'

if [[ ${1-} == --check ]]; then
  abi=$(current_abi) || die 'could not read the running Hyprland ABI'
  installed_abi=$(cat "$abi_marker" 2>/dev/null || true)
  if [[ $installed_abi != "$abi" ]]; then
    notify_rebuild 'Run hyprbars-setup in a terminal after this Hyprland upgrade.'
    exit 0
  fi
  if ! hyprpm reload >/dev/null 2>&1; then
    notify_rebuild 'The saved plugin could not be loaded. Run hyprbars-setup.'
    exit 0
  fi
  if ! hyprctl plugin list -j | jq -e \
    'any(.[]?; ((.name // "") | ascii_downcase) == "hyprbars")' >/dev/null; then
    notify_rebuild 'The ABI matches, but hyprbars is not loaded. Run hyprbars-setup.'
    exit 0
  fi
  if ! hyprctl reload >/dev/null 2>&1; then
    notify_rebuild 'Hyprbars loaded, but the compositor config could not be refreshed.'
  fi
  exit 0
fi

[[ $# -eq 0 ]] || die 'usage: hyprbars-setup [--check]'
[[ -t 0 ]] || die 'run this helper interactively; hyprpm may require sudo authentication'
[[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]] || die 'run this helper inside the Hyprland session'

mkdir -p -- "$state_dir"
chmod 0700 -- "$state_dir"
exec 9>"$state_dir/setup.lock"
flock 9

# hyprpm maps the installed Hyprland ABI to the official repository's pinned
# revision. update may authenticate to prepare matching compositor headers.
hyprpm update
if ! hyprpm list 2>/dev/null | grep -Fq 'hyprland-plugins'; then
  hyprpm add "$plugin_repository"
fi
hyprpm update
hyprpm enable hyprbars
hyprpm reload
hyprctl reload

abi=$(current_abi)
tmp_marker=$abi_marker.tmp.$$
printf '%s\n' "$abi" >"$tmp_marker"
chmod 0600 -- "$tmp_marker"
mv -f -- "$tmp_marker" "$abi_marker"

printf 'hyprbars is enabled for Hyprland ABI %s.\n' "$abi"
