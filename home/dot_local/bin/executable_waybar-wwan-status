#!/usr/bin/env bash
set -u

emit() {
  local text_value=$1
  local tooltip_value=$2
  local class_value=$3

  if command -v jq >/dev/null 2>&1; then
    jq -cn \
      --arg text "$text_value" \
      --arg tooltip "$tooltip_value" \
      --arg class "$class_value" \
      '{text: $text, tooltip: $tooltip, class: $class}'
  else
    printf '{"text":"WWAN","tooltip":"WWAN status unavailable","class":"unavailable"}\n'
  fi
}

if ! command -v mmcli >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
  emit "󰢔  WWAN" "WWAN tools unavailable" "unavailable"
  exit 0
fi

modem_path=$(mmcli -L -J 2>/dev/null | jq -r '."modem-list"[0] // empty' 2>/dev/null)
if [[ -z "$modem_path" ]]; then
  emit "󰢔  WWAN" "WWAN modem not detected" "unavailable"
  exit 0
fi

# Reduce ModemManager output immediately to non-identifying radio state.
safe_state=$(mmcli -m "$modem_path" -J 2>/dev/null | jq -c '{
    state: (.modem.generic.state // "unknown"),
    signal: ((.modem.generic["signal-quality"].value // 0) | tonumber? // 0),
    access: ((.modem.generic["access-technologies"] // []) | map(ascii_downcase))
}' 2>/dev/null)

if [[ -z "$safe_state" ]]; then
  emit "󰢔  WWAN" "WWAN status unavailable" "unavailable"
  exit 0
fi

state=$(jq -r '.state' <<<"$safe_state")
signal=$(jq -r '.signal | floor' <<<"$safe_state")
if ((signal < 0)); then signal=0; fi
if ((signal > 100)); then signal=100; fi

if jq -e '.access | index("5gnr") != null' <<<"$safe_state" >/dev/null; then
  radio=5G
elif jq -e '.access | index("lte") != null' <<<"$safe_state" >/dev/null; then
  radio=LTE
elif jq -e '.access | any(. == "umts" or . == "hspa" or . == "hspa-plus")' \
  <<<"$safe_state" >/dev/null; then
  radio=3G
else
  radio=WWAN
fi

case "$state" in
  connected)
    emit "󰢔  $radio  ${signal}%" \
      "WWAN connected\nRadio: $radio\nSignal: ${signal}%" \
      "connected"
    ;;
  connecting | registered)
    emit "󰢔  $radio" "WWAN state: $state\nRadio: $radio" "connecting"
    ;;
  *)
    emit "󰢔  WWAN" "WWAN state: $state" "disconnected"
    ;;
esac
