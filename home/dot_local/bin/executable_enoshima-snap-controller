#!/usr/bin/env python3
"""Small, discrete client for the persistent Enoshima window broker."""

from __future__ import annotations

import argparse
import json
import os
import socket
import subprocess
import sys
import uuid
from pathlib import Path
from typing import Any


def fail(message: str) -> None:
    print(f"enoshima-snap-controller: {message}", file=sys.stderr)
    raise SystemExit(1)


def runtime_paths() -> tuple[Path, Path]:
    runtime = Path(os.environ.get("ENOSHIMA_WINDOWD_RUNTIME_DIR", os.environ.get("XDG_RUNTIME_DIR", "")))
    if not runtime.is_absolute():
        fail("XDG_RUNTIME_DIR must be absolute")
    return runtime / "enoshima/windowd.sock", runtime / "enoshima/snap.json"


def current_state(path: Path) -> dict[str, Any]:
    try:
        document = json.loads(path.read_text(encoding="utf-8"))
        return document if document.get("schema") == 2 else {}
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return {}


def active_address() -> str:
    hyprctl = os.environ.get("ENOSHIMA_WINDOWD_HYPRCTL", os.environ.get("ENOSHIMA_SNAP_HYPRCTL", "hyprctl"))
    try:
        result = subprocess.run([hyprctl, "activewindow", "-j"], check=True, capture_output=True, text=True, timeout=2)
        return str(json.loads(result.stdout).get("address", ""))
    except (FileNotFoundError, subprocess.SubprocessError, json.JSONDecodeError):
        return ""


def request(document: dict[str, Any]) -> dict[str, Any]:
    socket_path, _ = runtime_paths()
    connection = socket.socket(socket.AF_UNIX, socket.SOCK_SEQPACKET)
    try:
        connection.settimeout(2)
        connection.connect(str(socket_path))
        connection.sendall(json.dumps(document, separators=(",", ":")).encode("utf-8"))
        response = json.loads(connection.recv(65536).decode("utf-8"))
    except (FileNotFoundError, ConnectionError, socket.timeout, json.JSONDecodeError) as error:
        fail(f"window broker is unavailable: {error}")
    finally:
        connection.close()
    if not response.get("ok") and not response.get("ignored"):
        fail(str(response.get("error", "request failed")))
    return response


def main() -> None:
    parser = argparse.ArgumentParser()
    commands = parser.add_subparsers(dest="command", required=True)

    preview = commands.add_parser("preview")
    preview.add_argument("--address", required=True)
    preview.add_argument("--x", required=True, type=int)
    preview.add_argument("--y", required=True, type=int)
    preview.add_argument("--session", required=True)
    preview.add_argument("--sequence", required=True, type=int)
    preview.add_argument("--source", default="titlebar")

    acquire = commands.add_parser("acquire")
    acquire.add_argument("--address", required=True)
    acquire.add_argument("--session", required=True)
    acquire.add_argument("--sequence", required=True, type=int)
    acquire.add_argument("--source", default="controller")

    for name in ("commit", "cancel", "release"):
        command = commands.add_parser(name)
        command.add_argument("--address")
        command.add_argument("--session")
        command.add_argument("--sequence", type=int)

    place = commands.add_parser("place")
    place.add_argument("target")
    place.add_argument("--address")

    chooser = commands.add_parser("chooser")
    chooser.add_argument("--address")
    chooser.add_argument("--target", default="left-half")

    choose = commands.add_parser("choose")
    choose.add_argument("cell_id")
    choose.add_argument("--commit", action="store_true")

    arguments = parser.parse_args()
    _, state_path = runtime_paths()
    state = current_state(state_path)
    address = getattr(arguments, "address", None) or str(state.get("address", "")) or active_address()

    if arguments.command == "place":
        request({"schema": 2, "command": "place", "address": address, "target": arguments.target})
        return

    if arguments.command == "acquire":
        request(
            {
                "schema": 2,
                "command": "acquire",
                "address": address,
                "session": arguments.session,
                "sequence": arguments.sequence,
                "source": arguments.source,
            }
        )
        return

    if arguments.command == "preview":
        request(
            {
                "schema": 2,
                "command": "preview",
                "address": address,
                "x": arguments.x,
                "y": arguments.y,
                "session": arguments.session,
                "sequence": arguments.sequence,
                "source": arguments.source,
            }
        )
        return

    if arguments.command == "chooser":
        session = uuid.uuid4().hex
        request(
            {
                "schema": 2,
                "command": "acquire",
                "address": address,
                "session": session,
                "sequence": 1,
                "source": "keyboard",
            }
        )
        request(
            {
                "schema": 2,
                "command": "chooser",
                "address": address,
                "target": arguments.target,
                "session": session,
                "sequence": 2,
                "source": "keyboard",
            }
        )
        return

    session = str(getattr(arguments, "session", "") or state.get("session", ""))
    sequence = int(getattr(arguments, "sequence", 0) or int(state.get("sequence", 0)) + 1)
    if arguments.command == "choose":
        request(
            {
                "schema": 2,
                "command": "choose",
                "address": address,
                "cellId": arguments.cell_id,
                "session": session,
                "sequence": sequence,
                "source": "keyboard",
                "commit": arguments.commit,
            }
        )
        return

    request(
        {
            "schema": 2,
            "command": arguments.command,
            "address": address,
            "session": session,
            "sequence": sequence,
        }
    )


if __name__ == "__main__":
    main()
