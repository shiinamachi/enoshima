#!/usr/bin/env python3
"""Persistent, address-safe window placement broker for Enoshima."""

from __future__ import annotations

import argparse
import json
import os
import selectors
import socket
import struct
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Any


TARGET_LABELS = {
    "left-half": "snap.left_half",
    "right-half": "snap.right_half",
    "upper-left": "snap.upper_left",
    "upper-right": "snap.upper_right",
    "lower-left": "snap.lower_left",
    "lower-right": "snap.lower_right",
    "bottom-half": "snap.bottom_half",
    "left-third": "snap.left_third",
    "center-third": "snap.center_third",
    "right-third": "snap.right_third",
    "left-two-thirds": "snap.left_two_thirds",
    "right-two-thirds": "snap.right_two_thirds",
    "maximize": "snap.maximize",
}

LAYOUTS = [
    {
        "id": "halves",
        "cells": [
            {"cellId": "halves:0", "target": "left-half", "x": 0, "y": 0, "width": 0.5, "height": 1},
            {"cellId": "halves:1", "target": "right-half", "x": 0.5, "y": 0, "width": 0.5, "height": 1},
        ],
    },
    {
        "id": "third-two-thirds",
        "cells": [
            {"cellId": "third-two-thirds:0", "target": "left-third", "x": 0, "y": 0, "width": 0.333, "height": 1},
            {"cellId": "third-two-thirds:1", "target": "right-two-thirds", "x": 0.333, "y": 0, "width": 0.667, "height": 1},
        ],
    },
    {
        "id": "two-thirds-third",
        "cells": [
            {"cellId": "two-thirds-third:0", "target": "left-two-thirds", "x": 0, "y": 0, "width": 0.667, "height": 1},
            {"cellId": "two-thirds-third:1", "target": "right-third", "x": 0.667, "y": 0, "width": 0.333, "height": 1},
        ],
    },
    {
        "id": "thirds",
        "cells": [
            {"cellId": "thirds:0", "target": "left-third", "x": 0, "y": 0, "width": 0.333, "height": 1},
            {"cellId": "thirds:1", "target": "center-third", "x": 0.333, "y": 0, "width": 0.334, "height": 1},
            {"cellId": "thirds:2", "target": "right-third", "x": 0.667, "y": 0, "width": 0.333, "height": 1},
        ],
    },
    {
        "id": "quarters",
        "cells": [
            {"cellId": "quarters:0", "target": "upper-left", "x": 0, "y": 0, "width": 0.5, "height": 0.5},
            {"cellId": "quarters:1", "target": "upper-right", "x": 0.5, "y": 0, "width": 0.5, "height": 0.5},
            {"cellId": "quarters:2", "target": "lower-left", "x": 0, "y": 0.5, "width": 0.5, "height": 0.5},
            {"cellId": "quarters:3", "target": "lower-right", "x": 0.5, "y": 0.5, "width": 0.5, "height": 0.5},
        ],
    },
    {
        "id": "maximize",
        "cells": [{"cellId": "maximize:0", "target": "maximize", "x": 0, "y": 0, "width": 1, "height": 1}],
    },
]

CELLS = [cell for layout in LAYOUTS for cell in layout["cells"]]


@dataclass
class ActiveLease:
    session: str
    address: str
    source: str
    monitor: str
    acquired_sequence: int
    latest_sequence: int
    state_revision: int
    acquired_at_ns: int


def fail(message: str) -> None:
    print(f"enoshima-windowd: {message}", file=sys.stderr)
    raise SystemExit(1)


def valid_address(value: object) -> bool:
    if not isinstance(value, str) or not value.startswith("0x"):
        return False
    try:
        int(value[2:], 16)
    except ValueError:
        return False
    return len(value) > 2


class WindowBroker:
    def __init__(self) -> None:
        runtime = Path(os.environ.get("ENOSHIMA_WINDOWD_RUNTIME_DIR", os.environ.get("XDG_RUNTIME_DIR", "")))
        if not runtime.is_absolute() or not runtime.is_dir() or runtime.owner() != Path.home().owner():
            fail("XDG_RUNTIME_DIR must be an existing absolute user-owned directory")

        self.runtime_dir = runtime / "enoshima"
        self.runtime_dir.mkdir(mode=0o700, exist_ok=True)
        if self.runtime_dir.is_symlink():
            fail("runtime directory must not be a symbolic link")
        os.chmod(self.runtime_dir, 0o700)
        self.socket_path = self.runtime_dir / "windowd.sock"
        self.state_path = self.runtime_dir / "snap.json"
        self.hyprctl = os.environ.get("ENOSHIMA_WINDOWD_HYPRCTL", os.environ.get("ENOSHIMA_SNAP_HYPRCTL", "hyprctl"))
        self.config_path = Path(
            os.environ.get(
                "ENOSHIMA_WINDOW_INTERACTION_CONFIG",
                str(Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "enoshima/window-interaction.yaml"),
            )
        )
        self.edge_threshold = self.config_int(".snap.edge_threshold", 16)
        self.preview_inset = self.config_int(".snap.preview_inset", 10)
        self.gap = self.config_int(".snap.gap", 10)
        self.stale_after_ms = self.config_int(".snap.stale_after_ms", 750)
        self.chooser_hold_ms = self.config_int(".snap.chooser_hold_ms", 300)
        self.sessions: dict[str, dict[str, Any]] = {}
        self.active_lease: ActiveLease | None = None
        self.state_revision = 0
        self.last_window_health_check = 0.0
        self.state = self.inactive_state()
        self.monitor_cache: tuple[float, list[dict[str, Any]]] = (0.0, [])
        self.publish_state(self.state)

    def config_int(self, expression: str, fallback: int) -> int:
        try:
            result = subprocess.run(
                ["yq", "-r", f"{expression} // {fallback}", str(self.config_path)],
                check=True,
                capture_output=True,
                text=True,
                timeout=2,
            )
            value = int(result.stdout.strip())
            return value if value >= 0 else fallback
        except (FileNotFoundError, subprocess.SubprocessError, ValueError):
            return fallback

    @staticmethod
    def now_ms() -> int:
        return time.time_ns() // 1_000_000

    def inactive_state(self, session: str = "", sequence: int = 0) -> dict[str, Any]:
        return {
            "schema": 2,
            "active": False,
            "session": session,
            "sequence": sequence,
            "updatedAt": self.now_ms(),
        }

    def publish_state(self, document: dict[str, Any]) -> None:
        self.state_revision += 1
        document["stateRevision"] = self.state_revision
        self.state = document
        if self.active_lease is not None:
            self.active_lease.state_revision = self.state_revision
        self.write_state(document)

    @staticmethod
    def session_token(request: dict[str, Any]) -> str:
        session = str(request.get("session", ""))
        normalized = session.replace("-", "")
        if len(normalized) < 32 or len(normalized) > 128 or not all(
            character in "0123456789abcdefABCDEF" for character in normalized
        ):
            raise ValueError("session must be an opaque hexadecimal token")
        return session

    @staticmethod
    def cell_for_id(cell_id: str) -> dict[str, Any] | None:
        return next((cell for cell in CELLS if cell["cellId"] == cell_id), None)

    @staticmethod
    def first_cell_id(target: str) -> str:
        cell = next((candidate for candidate in CELLS if candidate["target"] == target), None)
        if cell is None:
            raise ValueError(f"unsupported target: {target}")
        return str(cell["cellId"])

    def response(self, request: dict[str, Any], **values: Any) -> dict[str, Any]:
        response = {
            "schema": 2,
            "ok": True,
            "session": str(request.get("session", "")),
            "sequence": int(request.get("sequence", 0)),
            "stateRevision": self.state_revision,
        }
        response.update(values)
        return response

    def write_state(self, document: dict[str, Any]) -> None:
        descriptor, temporary = tempfile.mkstemp(prefix=".snap.", dir=self.runtime_dir, text=True)
        try:
            os.fchmod(descriptor, 0o600)
            with os.fdopen(descriptor, "w", encoding="utf-8") as stream:
                json.dump(document, stream, ensure_ascii=False, separators=(",", ":"))
                stream.write("\n")
            os.replace(temporary, self.state_path)
        except BaseException:
            try:
                os.close(descriptor)
            except OSError:
                pass
            Path(temporary).unlink(missing_ok=True)
            raise

    def hypr_json(self, resource: str) -> Any:
        result = subprocess.run(
            [self.hyprctl, resource, "-j"], check=True, capture_output=True, text=True, timeout=2
        )
        return json.loads(result.stdout)

    def dispatch(self, *arguments: str) -> None:
        subprocess.run([self.hyprctl, "dispatch", *arguments], check=True, timeout=3)

    def monitors(self) -> list[dict[str, Any]]:
        timestamp, cached = self.monitor_cache
        if time.monotonic() - timestamp >= 0.25:
            cached = self.hypr_json("monitors")
            self.monitor_cache = (time.monotonic(), cached)
        return cached

    @staticmethod
    def logical_size(monitor: dict[str, Any]) -> tuple[int, int]:
        scale = float(monitor.get("scale", 1)) or 1
        return int(float(monitor["width"]) / scale), int(float(monitor["height"]) / scale)

    def monitor_for_point(self, x: int, y: int) -> dict[str, Any] | None:
        for monitor in self.monitors():
            width, height = self.logical_size(monitor)
            if int(monitor["x"]) <= x < int(monitor["x"]) + width and int(monitor["y"]) <= y < int(monitor["y"]) + height:
                return monitor
        return None

    def monitor_for_address(self, address: str) -> dict[str, Any] | None:
        clients = self.hypr_json("clients")
        client = next((item for item in clients if item.get("address") == address), None)
        if client is None:
            return None
        return next((item for item in self.monitors() if item.get("id") == client.get("monitor")), None)

    def target_for_point(self, monitor: dict[str, Any], x: int, y: int) -> str | None:
        width, height = self.logical_size(monitor)
        monitor_x, monitor_y = int(monitor["x"]), int(monitor["y"])
        near_left = x - monitor_x <= self.edge_threshold
        near_right = monitor_x + width - 1 - x <= self.edge_threshold
        near_top = y - monitor_y <= self.edge_threshold
        near_bottom = monitor_y + height - 1 - y <= self.edge_threshold
        if near_left:
            if y < monitor_y + height // 3:
                return "upper-left"
            if y > monitor_y + height * 2 // 3:
                return "lower-left"
            return "left-half"
        if near_right:
            if y < monitor_y + height // 3:
                return "upper-right"
            if y > monitor_y + height * 2 // 3:
                return "lower-right"
            return "right-half"
        if near_top:
            return "maximize"
        if near_bottom:
            return "bottom-half"
        return None

    def geometry(self, monitor: dict[str, Any], target: str) -> dict[str, int]:
        logical_width, logical_height = self.logical_size(monitor)
        reserved = list(monitor.get("reserved", [0, 0, 0, 0])) + [0, 0, 0, 0]
        top, bottom, left, right = (int(value) for value in reserved[:4])
        monitor_x, monitor_y = int(monitor["x"]), int(monitor["y"])
        x = monitor_x + left + self.preview_inset
        y = monitor_y + top + self.preview_inset
        width = logical_width - left - right - self.preview_inset * 2
        height = logical_height - top - bottom - self.preview_inset * 2
        half_width = (width - self.gap) // 2
        half_height = (height - self.gap) // 2
        third_width = (width - self.gap * 2) // 3

        geometries = {
            "left-half": (x, y, half_width, height),
            "right-half": (x + half_width + self.gap, y, half_width, height),
            "upper-left": (x, y, half_width, half_height),
            "upper-right": (x + half_width + self.gap, y, half_width, half_height),
            "lower-left": (x, y + half_height + self.gap, half_width, half_height),
            "lower-right": (x + half_width + self.gap, y + half_height + self.gap, half_width, half_height),
            "bottom-half": (x, y + half_height + self.gap, width, half_height),
            "left-third": (x, y, third_width, height),
            "center-third": (x + third_width + self.gap, y, third_width, height),
            "right-third": (x + (third_width + self.gap) * 2, y, width - third_width * 2 - self.gap * 2, height),
            "left-two-thirds": (x, y, third_width * 2 + self.gap, height),
            "right-two-thirds": (x + third_width + self.gap, y, width - third_width - self.gap, height),
            "maximize": (x, y, width, height),
        }
        if target not in geometries:
            raise ValueError(f"unsupported target: {target}")
        target_x, target_y, target_width, target_height = geometries[target]
        return {
            "x": target_x,
            "y": target_y,
            "localX": target_x - monitor_x,
            "localY": target_y - monitor_y,
            "width": target_width,
            "height": target_height,
        }

    def state_for_target(
        self,
        monitor: dict[str, Any],
        target: str,
        address: str,
        session: str,
        sequence: int,
        source: str,
        chooser: bool = False,
        selected_cell_id: str = "",
    ) -> dict[str, Any]:
        if not selected_cell_id:
            selected_cell_id = self.first_cell_id(target)
        return {
            "schema": 2,
            "active": True,
            "session": session,
            "sequence": sequence,
            "address": address,
            "source": source,
            "target": target,
            "labelKey": TARGET_LABELS[target],
            "monitor": str(monitor["name"]),
            "monitorX": int(monitor["x"]),
            "monitorY": int(monitor["y"]),
            "geometry": self.geometry(monitor, target),
            "chooser": {
                "visible": chooser,
                "selectedTarget": target,
                "selectedCellId": selected_cell_id,
                "layouts": LAYOUTS if chooser else [],
            },
            "updatedAt": self.now_ms(),
        }

    def apply(self, document: dict[str, Any]) -> None:
        address, target = document.get("address"), document.get("target")
        if not valid_address(address):
            raise ValueError("invalid address")
        if not any(client.get("address") == address for client in self.hypr_json("clients")):
            raise ValueError("target window disappeared")
        if target == "maximize":
            self.dispatch(
                f'hl.dsp.window.fullscreen_state({{ internal = 1, client = 1, action = "set", window = "address:{address}" }})'
            )
            return
        geometry = document["geometry"]
        self.dispatch(
            f'hl.dsp.window.fullscreen_state({{ internal = 0, client = 0, action = "set", window = "address:{address}" }})'
        )
        self.dispatch(f'hl.dsp.window.float({{ action = "set", window = "address:{address}" }})')
        self.dispatch(
            f'hl.dsp.window.resize({{ x = {geometry["width"]}, y = {geometry["height"]}, '
            f'relative = false, window = "address:{address}" }})'
        )
        self.dispatch(
            f'hl.dsp.window.move({{ x = {geometry["x"]}, y = {geometry["y"]}, '
            f'relative = false, window = "address:{address}" }})'
        )
        self.dispatch(f'hl.dsp.focus({{ window = "address:{address}" }})')

    def session(self, request: dict[str, Any]) -> tuple[str, int, dict[str, Any]]:
        session = self.session_token(request)
        sequence = int(request.get("sequence", 0))
        if sequence <= 0:
            raise ValueError("sequence must be positive")
        record = self.sessions.setdefault(
            session,
            {
                "last": 0,
                "sealed": False,
                "target": None,
                "targetSince": time.monotonic(),
                "updatedAt": time.monotonic(),
            },
        )
        if record["sealed"] or sequence <= int(record["last"]):
            raise RuntimeError("stale-or-sealed")
        record["last"] = sequence
        record["updatedAt"] = time.monotonic()
        return session, sequence, record

    def ensure_owner(self, session: str, address: str, sequence: int) -> ActiveLease:
        lease = self.active_lease
        if lease is None or lease.session != session or lease.address != address:
            raise RuntimeError("not-active-owner")
        lease.latest_sequence = sequence
        return lease

    def seal_active_lease(self, session: str) -> None:
        record = self.sessions.get(session)
        if record is not None:
            record["sealed"] = True
            record["updatedAt"] = time.monotonic()
        if self.active_lease is not None and self.active_lease.session == session:
            self.active_lease = None

    def process(self, request: dict[str, Any]) -> dict[str, Any]:
        if int(request.get("schema", 0)) != 2:
            raise ValueError("unsupported protocol schema")
        kind = str(request.get("command", ""))
        if kind == "place":
            address = str(request.get("address", ""))
            target = str(request.get("target", ""))
            monitor = self.monitor_for_address(address)
            if monitor is None:
                raise ValueError("window monitor is unavailable")
            if self.active_lease is not None:
                self.seal_active_lease(self.active_lease.session)
            document = self.state_for_target(monitor, target, address, "", 0, "keyboard")
            self.apply(document)
            self.publish_state(self.inactive_state())
            return self.response(request, applied=target)

        session, sequence, record = self.session(request)
        address = str(request.get("address", ""))
        if not valid_address(address):
            raise ValueError("invalid address")

        if kind == "acquire":
            if self.active_lease is not None and self.active_lease.session == session and self.active_lease.address != address:
                raise RuntimeError("session-address-mismatch")
            if self.active_lease is not None and self.active_lease.session != session:
                self.seal_active_lease(self.active_lease.session)
            monitor = self.monitor_for_address(address)
            self.active_lease = ActiveLease(
                session=session,
                address=address,
                source=str(request.get("source", "unknown")),
                monitor=str(monitor.get("name", "")) if monitor else "",
                acquired_sequence=sequence,
                latest_sequence=sequence,
                state_revision=self.state_revision,
                acquired_at_ns=time.monotonic_ns(),
            )
            self.publish_state(self.inactive_state(session, sequence))
            return self.response(request, accepted=True)

        self.ensure_owner(session, address, sequence)

        if kind == "preview":
            x, y = int(request["x"]), int(request["y"])
            monitor = self.monitor_for_point(x, y)
            target = self.target_for_point(monitor, x, y) if monitor else None
            if target != record["target"]:
                record["target"] = target
                record["targetSince"] = time.monotonic()
            if monitor is None or target is None:
                document = self.inactive_state(session, sequence)
            else:
                if self.active_lease is not None:
                    self.active_lease.monitor = str(monitor["name"])
                chooser = target == "maximize" and (time.monotonic() - float(record["targetSince"])) * 1000 >= self.chooser_hold_ms
                document = self.state_for_target(
                    monitor,
                    target,
                    address,
                    session,
                    sequence,
                    str(request.get("source", "titlebar")),
                    chooser,
                )
            self.publish_state(document)
            return self.response(request, active=self.state["active"])

        if kind == "chooser":
            monitor = self.monitor_for_address(address)
            if monitor is None:
                raise ValueError("window monitor is unavailable")
            target = str(request.get("target", "left-half"))
            document = self.state_for_target(
                monitor,
                target,
                address,
                session,
                sequence,
                str(request.get("source", "keyboard")),
                True,
            )
            self.publish_state(document)
            return self.response(request, chooser=True)

        if kind == "choose":
            if str(self.state.get("session", "")) != session or self.state.get("address") != address:
                raise RuntimeError("session-mismatch")
            monitor = self.monitor_for_address(address)
            if monitor is None:
                raise ValueError("window monitor is unavailable")
            cell_id = str(request.get("cellId", ""))
            cell = self.cell_for_id(cell_id)
            if cell is None:
                raise ValueError("unknown snap cell")
            target = str(cell["target"])
            document = self.state_for_target(
                monitor,
                target,
                address,
                session,
                sequence,
                str(request.get("source", "keyboard")),
                True,
                cell_id,
            )
            if bool(request.get("commit", False)):
                self.apply(document)
                self.seal_active_lease(session)
                self.publish_state(self.inactive_state(session, sequence))
            else:
                self.publish_state(document)
            return self.response(request, applied=target if record["sealed"] else None)

        if kind == "commit":
            if str(self.state.get("session", "")) != session or self.state.get("address") != address:
                self.seal_active_lease(session)
                return self.response(request, applied=None)
            if bool(self.state.get("chooser", {}).get("visible", False)):
                self.state["source"] = "chooser"
                self.state["updatedAt"] = self.now_ms()
                self.publish_state(self.state)
                return self.response(request, awaitingChoice=True)
            if self.state.get("active") and self.now_ms() - int(self.state.get("updatedAt", 0)) <= self.stale_after_ms:
                self.apply(self.state)
            self.seal_active_lease(session)
            self.publish_state(self.inactive_state(session, sequence))
            return self.response(request, applied=True)

        if kind in {"cancel", "release"}:
            self.seal_active_lease(session)
            self.publish_state(self.inactive_state(session, sequence))
            return self.response(request, cancelled=kind == "cancel", released=kind == "release")

        raise ValueError(f"unsupported request type: {kind}")

    def expire(self) -> None:
        now = time.monotonic()
        if self.state.get("active"):
            chooser = bool(self.state.get("chooser", {}).get("visible", False))
            maximum_age = 15_000 if chooser else max(900, self.stale_after_ms + 150)
            if self.now_ms() - int(self.state.get("updatedAt", 0)) > maximum_age:
                session = str(self.state.get("session", ""))
                self.seal_active_lease(session)
                self.publish_state(self.inactive_state(session, int(self.state.get("sequence", 0))))

        if self.active_lease is not None and now - self.last_window_health_check >= 1.0:
            self.last_window_health_check = now
            try:
                addresses = {str(client.get("address", "")) for client in self.hypr_json("clients")}
            except (subprocess.SubprocessError, json.JSONDecodeError):
                addresses = {self.active_lease.address}
            if self.active_lease.address not in addresses:
                session = self.active_lease.session
                sequence = self.active_lease.latest_sequence
                self.seal_active_lease(session)
                self.publish_state(self.inactive_state(session, sequence))

        active_session = self.active_lease.session if self.active_lease else ""
        expired = [
            session
            for session, record in self.sessions.items()
            if session != active_session and now - float(record["updatedAt"]) >= 30.0
        ]
        for session in expired:
            self.sessions.pop(session, None)
        if len(self.sessions) > 256:
            removable = sorted(
                (
                    (float(record["updatedAt"]), session)
                    for session, record in self.sessions.items()
                    if session != active_session
                )
            )
            for _, session in removable[: len(self.sessions) - 256]:
                self.sessions.pop(session, None)

    def serve(self) -> None:
        if self.socket_path.exists() or self.socket_path.is_symlink():
            self.socket_path.unlink()
        listener = socket.socket(socket.AF_UNIX, socket.SOCK_SEQPACKET)
        listener.bind(str(self.socket_path))
        os.chmod(self.socket_path, 0o600)
        listener.listen(16)
        listener.setblocking(False)
        selector = selectors.DefaultSelector()
        selector.register(listener, selectors.EVENT_READ)
        try:
            while True:
                for key, _ in selector.select(timeout=0.25):
                    connection, _ = key.fileobj.accept()
                    with connection:
                        credentials = connection.getsockopt(socket.SOL_SOCKET, socket.SO_PEERCRED, struct.calcsize("3i"))
                        _, uid, _ = struct.unpack("3i", credentials)
                        if uid != os.getuid():
                            connection.sendall(b'{"ok":false,"error":"peer-uid"}\n')
                            continue
                        request: dict[str, Any] = {}
                        try:
                            request = json.loads(connection.recv(65536).decode("utf-8"))
                            response = self.process(request)
                        except RuntimeError as error:
                            response = {
                                "schema": 2,
                                "ok": False,
                                "ignored": str(error),
                                "session": str(request.get("session", "")) if isinstance(request, dict) else "",
                                "sequence": int(request.get("sequence", 0)) if isinstance(request, dict) else 0,
                                "activeSession": self.active_lease.session if self.active_lease else "",
                                "stateRevision": self.state_revision,
                            }
                        except (KeyError, TypeError, ValueError, subprocess.SubprocessError, json.JSONDecodeError) as error:
                            response = {
                                "schema": 2,
                                "ok": False,
                                "error": str(error),
                                "session": str(request.get("session", "")) if isinstance(request, dict) else "",
                                "sequence": int(request.get("sequence", 0)) if isinstance(request, dict) else 0,
                                "stateRevision": self.state_revision,
                            }
                        try:
                            connection.sendall((json.dumps(response, separators=(",", ":")) + "\n").encode("utf-8"))
                        except (BrokenPipeError, ConnectionResetError):
                            pass
                self.expire()
        finally:
            selector.close()
            listener.close()
            self.socket_path.unlink(missing_ok=True)


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--check", action="store_true", help="validate dependencies and configuration without serving")
    arguments = parser.parse_args()
    broker = WindowBroker()
    if arguments.check:
        print(json.dumps({"schema": 2, "valid": True, "socket": str(broker.socket_path)}))
        return
    broker.serve()


if __name__ == "__main__":
    main()
