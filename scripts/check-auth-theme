#!/usr/bin/python
from __future__ import annotations

from pathlib import Path
import json
import re
import sys

import yaml


ROOT = Path(__file__).resolve().parent.parent
THEME = ROOT / "home/dot_config/enoshima/auth-theme.yaml"
LAYOUT = ROOT / "home/dot_config/enoshima/auth-layout.yaml"
CSS = ROOT / "ansible/roles/system/templates/enoshima-greeter.css.j2"
LOCK = ROOT / "home/dot_config/hypr/hyprlock.conf"


def rgb(hex_color: str) -> str:
    value = hex_color.removeprefix("#")
    return ", ".join(
        str(int(value[index : index + 2], 16)) for index in (0, 2, 4)
    )


def main() -> int:
    theme = yaml.safe_load(THEME.read_text(encoding="utf-8"))
    layout = yaml.safe_load(LAYOUT.read_text(encoding="utf-8"))
    css = CSS.read_text(encoding="utf-8")
    lock = LOCK.read_text(encoding="utf-8")
    if theme.get("schema") != 1 or theme.get("direction") != "outline-frame":
        raise SystemExit("auth theme schema/direction is invalid")
    if layout.get("schema") != 1 or layout.get("surface") != "auth":
        raise SystemExit("auth layout schema/surface is invalid")
    if layout.get("authentication", {}).get("policy") != "serialized":
        raise SystemExit("auth layout must declare serialized PAM policy")
    if theme.get("layout") != str(LAYOUT.relative_to(ROOT)):
        raise SystemExit("auth theme does not reference the shared layout")

    catalogs: dict[str, dict[str, str]] = {}
    for locale, relative in theme.get("i18n", {}).items():
        path = ROOT / relative
        catalogs[locale] = json.loads(path.read_text(encoding="utf-8"))
    if set(catalogs) != {"en-US", "ko-KR"}:
        raise SystemExit("auth theme must reference English and Korean catalogs")
    if set(catalogs["en-US"]) != set(catalogs["ko-KR"]):
        raise SystemExit("auth translation catalogs do not have matching keys")

    for name, value in theme["colors"].items():
        expected = f"@define-color cyber_{name} {value};"
        if expected not in css:
            raise SystemExit(f"greeter CSS is missing auth token: {expected}")
        if f"rgba({rgb(value)}," not in lock:
            raise SystemExit(f"Hyprlock is missing auth token: {name}={value}")

    geometry = theme["geometry"]
    layout_geometry = layout["card"] | layout["controls"]
    shared_geometry = {
        "content_width": "content_width",
        "frame_width": "frame_width",
        "frame_height": "frame_height",
        "primary_height": "primary_height",
        "control_radius": "radius",
        "focus_width": "focus_width",
    }
    for theme_key, layout_key in shared_geometry.items():
        if geometry[theme_key] != layout_geometry[layout_key]:
            raise SystemExit(
                f"auth geometry drift between theme and layout: {theme_key}"
            )
    contracts = {
        f"size = {geometry['frame_width']}, {geometry['frame_height']}",
        f"size = {geometry['content_width']}, 58",
        f"size = {geometry['content_width']}, {geometry['primary_height']}",
        f"rounding = {geometry['radius']}",
    }
    missing = sorted(contract for contract in contracts if contract not in lock)
    if missing:
        raise SystemExit("Hyprlock geometry drift: " + ", ".join(missing))
    if not re.search(
        rf"\.auth-card\s*\{{.*?min-width:\s*{geometry['content_width']}px;",
        css,
        flags=re.DOTALL,
    ):
        raise SystemExit("greeter auth-card width drift")
    if f"min-height: {geometry['primary_height']}px;" not in css:
        raise SystemExit("greeter primary action height drift")

    print("auth theme: shared tokens and geometry match greeter and Hyprlock")
    return 0


if __name__ == "__main__":
    sys.exit(main())
