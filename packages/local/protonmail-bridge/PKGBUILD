# Maintainer: Proton AG (Proton Mail Bridge developers) <bridge@protonmail.ch>
# Local review: 2026-07-13, based on https://proton.me/download/bridge/PKGBUILD

pkgname=protonmail-bridge
pkgver=3.25.0
pkgrel=1
_upstream_pkgrel=1
pkgdesc="Desktop bridge between Proton Mail and local IMAP/SMTP clients"
arch=(x86_64)
url="https://proton.me/mail/bridge"
license=(GPL-3.0-only)
depends=(
  gcc-libs
  glib2
  glibc
  libfido2
  libglvnd
  ttf-dejavu
  xcb-util-cursor
)
optdepends=(
  'gnome-keyring: Secret Service keychain selected by this workstation'
  'pass: alternative password-store keychain'
)
conflicts=(
  protonmail-bridge-beta-bin
  protonmail-bridge-bin
)
# Preserve Proton's prebuilt and signed launcher/application payload instead of
# rewriting its bundled Go, Qt, and ICU binaries through makepkg debug tools.
options=(!debug !strip)
source=(
  "${pkgname}_${pkgver}-${_upstream_pkgrel}_amd64.deb::https://proton.me/download/bridge/protonmail-bridge_${pkgver}-${_upstream_pkgrel}_amd64.deb"
)
sha256sums=(
  6b0318f4f425ef1a19b63e2bd589bc1036d95f073cb9ac26b42c0fc63a8bc275
)

package() {
  # makepkg extracts the Debian archive first; retain Proton's official
  # payload layout while excluding its Debian-only /opt integration.
  tar -xzf data.tar.gz -C "$pkgdir"
  rm -rf -- "$pkgdir/opt"

  [[ -x "$pkgdir/usr/lib/protonmail/bridge/proton-bridge" ]]
  [[ -f "$pkgdir/usr/share/applications/protonmail-bridge.desktop" ]]
}
