# Maintainer: local workstation configuration
pkgname=ttf-jetendard
pkgver=0.1.0.r0.g4b018fc
pkgrel=2
pkgdesc='Pretendard UI fonts and Jetendard Korean monospace fonts'
arch=('any')
url='https://github.com/kuskhan/jetendard'
license=('OFL-1.1')
depends=('fontconfig')
makedepends=('python-brotli' 'python-fonttools' 'python-pytest')
provides=('jetendard-font' 'pretendard-font')
_commit=4b018fcb9c6cc87fdb788aa27fe22b89f4110d7d
_nerd_fonts_version=3.4.0
_pretendard_version=1.3.9
source=(
  "jetendard-${_commit}.tar.gz::https://github.com/kuskhan/jetendard/archive/${_commit}.tar.gz"
  "JetBrainsMono-${_nerd_fonts_version}.zip::https://github.com/ryanoasis/nerd-fonts/releases/download/v${_nerd_fonts_version}/JetBrainsMono.zip"
  "Pretendard-${_pretendard_version}.zip::https://github.com/orioncactus/pretendard/releases/download/v${_pretendard_version}/Pretendard-${_pretendard_version}.zip"
)
sha256sums=(
  '07d777ed8e9ada85a842a8b07d4957e75e3ecec29540db0dc01c0d4741d3f9ba'
  '76f05ff3ace48a464a6ca57977998784ff7bdbb65a6d915d7e401cd3927c493c'
  '04be351a74d6bf7d60c480a3087e51d185485d35a52023142af1df19eb8c428a'
)

prepare() {
  cd "jetendard-${_commit}"
  mkdir -p upstream/jetbrainsmono upstream/pretendard
  bsdtar -xf "$srcdir/JetBrainsMono-${_nerd_fonts_version}.zip" \
    -C upstream/jetbrainsmono 'JetBrainsMonoNerdFontMono-*.ttf'
  bsdtar -xf "$srcdir/Pretendard-${_pretendard_version}.zip" \
    -C upstream/pretendard --strip-components 3 \
    'public/static/alternative/Pretendard-*.ttf'
  bsdtar -xf "$srcdir/Pretendard-${_pretendard_version}.zip" \
    -C upstream/pretendard 'LICENSE.txt'
}

build() {
  cd "jetendard-${_commit}"
  PYTHONPATH="src${PYTHONPATH:+:$PYTHONPATH}" \
    /usr/bin/python -m jetendard.cli --all
}

check() {
  cd "jetendard-${_commit}"
  PYTHONPATH="src${PYTHONPATH:+:$PYTHONPATH}" \
    /usr/bin/python -m pytest

  local -a built_fonts=(fonts/ttf/Jetendard-*.ttf)
  local -a pretendard_fonts=(upstream/pretendard/Pretendard-*.ttf)
  (( ${#built_fonts[@]} == 16 )) || {
    printf 'expected 16 TTF variants, found %d\n' "${#built_fonts[@]}" >&2
    return 1
  }
  (( ${#pretendard_fonts[@]} == 9 )) || {
    printf 'expected 9 Pretendard TTF variants, found %d\n' "${#pretendard_fonts[@]}" >&2
    return 1
  }
  local family font
  for font in "${built_fonts[@]}"; do
    family=$(fc-scan --format '%{family[0]}' "$font")
    [[ $family == Jetendard ]] || {
      printf 'expected Jetendard family for %s, found %s\n' "$font" "$family" >&2
      return 1
    }
  done
  for font in "${pretendard_fonts[@]}"; do
    family=$(fc-scan --format '%{family[0]}' "$font")
    [[ $family == Pretendard ]] || {
      printf 'expected Pretendard family for %s, found %s\n' "$font" "$family" >&2
      return 1
    }
  done
}

package() {
  cd "jetendard-${_commit}"
  install -d "$pkgdir/usr/share/fonts/TTF"
  install -m 0644 fonts/ttf/Jetendard-*.ttf "$pkgdir/usr/share/fonts/TTF/"
  install -m 0644 upstream/pretendard/Pretendard-*.ttf "$pkgdir/usr/share/fonts/TTF/"
  install -Dm0644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm0644 upstream/pretendard/LICENSE.txt \
    "$pkgdir/usr/share/licenses/$pkgname/PRETENDARD-LICENSE"
}
